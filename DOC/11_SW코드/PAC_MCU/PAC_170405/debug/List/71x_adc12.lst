     25          /*******************************************************************************
     26          * Function Name      : ADC12_Init
     27          * Description        : This routine is used to initialize the ADC12 registers to
     28          *                      their reset values.
     29          * Input              : None.
     30          * Output             : None.
     31          * Return             : None.
     32          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     33          void ADC12_Init(void)
     34          {
     35            /* Initiate ADC12 registers to their reset values */
     36            ADC12->CSR  = 0x0000;
   \                     ADC12_Init:
   \        0x0   0xE3A0'0000        MOV      R0,#+0
   \        0x4   0x....'....        LDR      R1,??DataTable6  ;; 0xe0007020
   \        0x8   0xE1C1'00B0        STRH     R0,[R1, #+0]
     37            ADC12->CPR  = 0x0005;
   \        0xC   0xE3A0'0005        MOV      R0,#+5
   \       0x10   0x....'....        LDR      R1,??DataTable6_1  ;; 0xe0007030
   \       0x14   0xE1C1'00B0        STRH     R0,[R1, #+0]
     38          }
   \       0x18   0xE12F'FF1E        BX       LR               ;; return
     39          
     40          /*******************************************************************************
     41          * Function Name      : ADC12_ConversionStart
     42          * Description        : This routine is used to launch the conversion.
     43          * Input              : None.
     44          * Output             : None.
     45          * Return             : None.
     46          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     47          void ADC12_ConversionStart (void)
     48          {
     49            /* Set the ADCen bit of the BOOTCR register */
     50            PCU->BOOTCR |= ADC12_Start_Mask;
   \                     ADC12_ConversionStart:
   \        0x0   0xE3A0'0050        MOV      R0,#+80
   \        0x4   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \        0x8   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \        0xC   0xE391'1020        ORRS     R1,R1,#0x20
   \       0x10   0xE1C0'10B0        STRH     R1,[R0, #+0]
     51          }
   \       0x14   0xE12F'FF1E        BX       LR               ;; return
     52          
     53          /*******************************************************************************
     54          * Function Name      : ADC12_ConversionStop
     55          * Description        : This routine is used to disable the ADC12 cell.
     56          * Input              : None.
     57          * Output             : None.
     58          * Return             : None.
     59          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     60          void ADC12_ConversionStop(void)
     61          {
     62            /* Clear the ADCen bit of the BOOTCR register */
     63            PCU->BOOTCR &= ~ADC12_Start_Mask;
   \                     ADC12_ConversionStop:
   \        0x0   0xE3A0'0050        MOV      R0,#+80
   \        0x4   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \        0x8   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \        0xC   0xE3A0'20DF        MOV      R2,#+223
   \       0x10   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x14   0xE012'1001        ANDS     R1,R2,R1
   \       0x18   0xE1C0'10B0        STRH     R1,[R0, #+0]
     64          }
   \       0x1C   0xE12F'FF1E        BX       LR               ;; return
     65          
