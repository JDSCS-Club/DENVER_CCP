     27          /*******************************************************************************
     28          * Function Name  : I2C_Init
     29          * Description    : Initializes I2C peripheral control and registers to their
     30          *                  default reset values.
     31          * Input          : - I2Cx: specifies the I2C to be initialized, it can be:
     32          *                     I2C0, I2C1
     33          * Output         : None.
     34          * Return         : None.
     35          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     36          void I2C_Init (I2C_TypeDef *I2Cx)
     37          {
     38            /* Initialize all the register of the specified I2C passed as parameter */
     39            I2Cx->CR = 0x0;
   \                     I2C_Init:
   \        0x0   0xE3A0'1000        MOV      R1,#+0
   \        0x4   0xE5C0'1000        STRB     R1,[R0, #+0]
     40            I2Cx->CCR = 0x0;
   \        0x8   0xE5C0'100C        STRB     R1,[R0, #+12]
     41            I2Cx->ECCR = 0x0;
   \        0xC   0xE5C0'101C        STRB     R1,[R0, #+28]
     42            I2Cx->OAR1 = 0x0;
   \       0x10   0xE5C0'1010        STRB     R1,[R0, #+16]
     43            I2Cx->OAR2 = 0x0;
   \       0x14   0xE5C0'1014        STRB     R1,[R0, #+20]
     44            (void)I2Cx->SR1;
   \       0x18   0xE5D0'2004        LDRB     R2,[R0, #+4]
     45            (void)I2Cx->SR2;
   \       0x1C   0xE5D0'2008        LDRB     R2,[R0, #+8]
     46            I2Cx->DR = 0x0;
   \       0x20   0xE5C0'1018        STRB     R1,[R0, #+24]
     47          }
   \       0x24   0xE12F'FF1E        BX       LR               ;; return
     48          
     49          /*******************************************************************************
     50          * Function Name  : I2C_OnOffConfig
     51          * Description    : Enables or disables the I2C peripheral.
     52          * Input          : - I2Cx: specifies the I2C to be enabled or disabled.
     53          *                    It can be:
     54          *                     I2C0, I2C1
     55          *                  - NewState: specifies the new status to set. It can be:
     56          *                     ENABLE: enables the I2C peripheral.
     57          *                     DISABLE: disables the I2C peripheral.
     58          * Output         : None.
     59          * Return         : None.
     60          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     61          void I2C_OnOffConfig (I2C_TypeDef *I2Cx, FunctionalState NewState)
     62          {
     63            if (NewState == ENABLE)
   \                     I2C_OnOffConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0006        BNE      ??I2C_OnOffConfig_0
     64            {
     65              /* Enable the I2C selected by setting twice the PE bit on the CR register */
     66              I2Cx->CR |= I2C_PESET_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1020        ORRS     R1,R1,#0x20
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
     67              I2Cx->CR |= I2C_PESET_Mask;
   \       0x18   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x1C   0xE391'1020        ORRS     R1,R1,#0x20
   \       0x20   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x24   0xEA00'0002        B        ??I2C_OnOffConfig_1
     68            }
     69            else
     70            {
     71              /* Disable the I2C selected */
     72              I2Cx->CR &= ~I2C_PESET_Mask;
   \                     ??I2C_OnOffConfig_0:
   \       0x28   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x2C   0xE211'10DF        ANDS     R1,R1,#0xDF
   \       0x30   0xE5C0'1000        STRB     R1,[R0, #+0]
     73            }
     74          }
   \                     ??I2C_OnOffConfig_1:
   \       0x34   0xE12F'FF1E        BX       LR               ;; return
     75          
     76          /*******************************************************************************
     77          * Function Name  : I2C_GeneralCallConfig
     78          * Description    : Enables or disables I2C general call option.
     79          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
     80          *                     I2C0, I2C1
     81          *                  - NewState: specifies the new status to set. It can be:
     82          *                     ENABLE: enables the I2C general call option.
     83          *                     DISABLE: disables the I2C general call option.
     84          * Output         : None.
     85          * Return         : None.
     86          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     87          void I2C_GeneralCallConfig (I2C_TypeDef *I2Cx, FunctionalState NewState)
     88          {
     89            if (NewState == ENABLE)
   \                     I2C_GeneralCallConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0003        BNE      ??I2C_GeneralCallConfig_0
     90            {
     91              I2Cx->CR |= I2C_ENGC_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1010        ORRS     R1,R1,#0x10
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x18   0xEA00'0002        B        ??I2C_GeneralCallConfig_1
     92            }
     93            else
     94            {
     95              I2Cx->CR &= ~I2C_ENGC_Mask;
   \                     ??I2C_GeneralCallConfig_0:
   \       0x1C   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x20   0xE211'10EF        ANDS     R1,R1,#0xEF
   \       0x24   0xE5C0'1000        STRB     R1,[R0, #+0]
     96            }
     97          }
   \                     ??I2C_GeneralCallConfig_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
     98          
     99          /*******************************************************************************
    100          * Function Name  : I2C_STARTGenerate
    101          * Description    : Generates I2C communication START condition.
    102          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    103          *                     I2C0, I2C1
    104          *                  - NewState: specifies the new status to set. It can be:
    105          *                     ENABLE: enables the I2C start generation.
    106          *                     DISABLE: disables the I2C start generation.
    107          * Output         : None.
    108          * Return         : None.
    109          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    110          void I2C_STARTGenerate (I2C_TypeDef *I2Cx, FunctionalState NewState)
    111          {
    112            if (NewState == ENABLE)
   \                     I2C_STARTGenerate:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0003        BNE      ??I2C_STARTGenerate_0
    113            {
    114              I2Cx->CR |= I2C_START_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1008        ORRS     R1,R1,#0x8
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x18   0xEA00'0002        B        ??I2C_STARTGenerate_1
    115            }
    116            else
    117            {
    118              I2Cx->CR &= ~I2C_START_Mask;
   \                     ??I2C_STARTGenerate_0:
   \       0x1C   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x20   0xE211'10F7        ANDS     R1,R1,#0xF7
   \       0x24   0xE5C0'1000        STRB     R1,[R0, #+0]
    119            }
    120          }
   \                     ??I2C_STARTGenerate_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
    121          
    122          /*******************************************************************************
    123          * Function Name  : I2C_STOPGenerate
    124          * Description    : Generates I2C communication STOP condition.
    125          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    126          *                     I2C0, I2C1
    127          *                  - NewState: specifies the new status to set. It can be:
    128          *                     ENABLE: enables the I2C stop generation.
    129          *                     DISABLE: disables the I2C stop generation.
    130          * Output         : None.
    131          * Return         : None.
    132          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    133          void I2C_STOPGenerate (I2C_TypeDef *I2Cx, FunctionalState NewState)
    134          {
    135            if (NewState == ENABLE)
   \                     I2C_STOPGenerate:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0003        BNE      ??I2C_STOPGenerate_0
    136            {
    137              I2Cx->CR |= I2C_STOP_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1002        ORRS     R1,R1,#0x2
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x18   0xEA00'0002        B        ??I2C_STOPGenerate_1
    138            }
    139            else
    140            {
    141              I2Cx->CR &= ~I2C_STOP_Mask;
   \                     ??I2C_STOPGenerate_0:
   \       0x1C   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x20   0xE211'10FD        ANDS     R1,R1,#0xFD
   \       0x24   0xE5C0'1000        STRB     R1,[R0, #+0]
    142            }
    143          }
   \                     ??I2C_STOPGenerate_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
    144          
    145          /*******************************************************************************
    146          * Function Name  : I2C_AcknowledgeConfig
    147          * Description    : Enables or disables I2C acknowledge feature.
    148          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    149          *                     I2C0, I2C1
