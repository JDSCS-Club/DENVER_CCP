    570          /*******************************************************************************
    571          * Function Name  : I2C_TransmissionStatus
    572          * Description    : Reports the current transmission status.
    573          * Input          : - I2Cx: specifies the I2C whose transmission status will be  
    574          *                    tested,it can be:
    575          *                     I2C0, I2C1
    576          * Output         : None.
    577          * Return         : The transmission status, it can be:
    578          *                   I2C_TX_NO, I2C_TX_SB, I2C_TX_AF, I2C_TX_ARLO, I2C_TX_BERR,
    579          *                   I2C_TX_ADD_OK, I2C_TX_DATA_OK, I2C_TX_ONGOING
    580          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    581          I2C_Tx_Status I2C_TransmissionStatus (I2C_TypeDef *I2Cx)
    582          {
    583            u8 SR1value = 0;
   \                     I2C_TransmissionStatus:
   \        0x0   0xE3A0'1000        MOV      R1,#+0
    584            u8 SR2value = 0;
   \        0x4   0xE3A0'1000        MOV      R1,#+0
    585            I2C_Tx_Status NewState = I2C_TX_NO;
   \        0x8   0xE3A0'1000        MOV      R1,#+0
    586          
    587            SR1value = I2Cx->SR1;
   \        0xC   0xE5D0'1004        LDRB     R1,[R0, #+4]
    588            SR2value = I2Cx->SR2;
   \       0x10   0xE5D0'2008        LDRB     R2,[R0, #+8]
    589            if ((I2Cx->SR1 & 0x10) == 0)
   \       0x14   0xE5D0'3004        LDRB     R3,[R0, #+4]
   \       0x18   0xE313'0010        TST      R3,#0x10
   \       0x1C   0x1A00'0001        BNE      ??I2C_TransmissionStatus_0
    590            {
    591              NewState = I2C_TX_NO;
   \       0x20   0xE3A0'0000        MOV      R0,#+0
   \       0x24   0xEA00'0023        B        ??I2C_TransmissionStatus_1
    592            }
    593            /* If I2C_SB bit is set */
    594            else if (I2Cx->SR1 & 0x01)
   \                     ??I2C_TransmissionStatus_0:
   \       0x28   0xE5D0'3004        LDRB     R3,[R0, #+4]
   \       0x2C   0xE313'0001        TST      R3,#0x1
   \       0x30   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_2
    595            {
    596               NewState = I2C_TX_SB;
   \       0x34   0xE3A0'0001        MOV      R0,#+1
   \       0x38   0xEA00'001E        B        ??I2C_TransmissionStatus_1
    597            }
    598            /* If I2C_ACK  and I2C_AF are both set */
    599            else if ((SR2value & 0x10) && (I2Cx->CR & 0x04))
   \                     ??I2C_TransmissionStatus_2:
   \       0x3C   0xE312'0010        TST      R2,#0x10
   \       0x40   0x0A00'0004        BEQ      ??I2C_TransmissionStatus_3
   \       0x44   0xE5D0'3000        LDRB     R3,[R0, #+0]
   \       0x48   0xE313'0004        TST      R3,#0x4
   \       0x4C   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_3
    600            {
    601              NewState = I2C_TX_AF;
   \       0x50   0xE3A0'0002        MOV      R0,#+2
   \       0x54   0xEA00'0017        B        ??I2C_TransmissionStatus_1
    602            }
    603            /* If I2C_ARLO is set in multimaster mode */
    604            else if (SR2value & 0x04)
   \                     ??I2C_TransmissionStatus_3:
   \       0x58   0xE312'0004        TST      R2,#0x4
   \       0x5C   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_4
    605            {
    606              NewState = I2C_TX_ARLO;
   \       0x60   0xE3A0'0003        MOV      R0,#+3
   \       0x64   0xEA00'0013        B        ??I2C_TransmissionStatus_1
    607            }
    608            /* If I2C_BERR bit is set */
    609            else if (SR2value & 0x02)
   \                     ??I2C_TransmissionStatus_4:
   \       0x68   0xE312'0002        TST      R2,#0x2
   \       0x6C   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_5
    610            {
    611              NewState = I2C_TX_BERR;
   \       0x70   0xE3A0'0004        MOV      R0,#+4
   \       0x74   0xEA00'000F        B        ??I2C_TransmissionStatus_1
    612            }
    613            /* If I2C_EVF and I2C_ENDAD are both set */
    614            else if ((SR1value & 0x80) && (I2Cx->SR2 & 0x20))
   \                     ??I2C_TransmissionStatus_5:
