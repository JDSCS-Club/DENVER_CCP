   \                                 In section .text, align 4, keep-with-next
    156          void I2C_AcknowledgeConfig (I2C_TypeDef *I2Cx, FunctionalState NewState)
    157          {
    158            if (NewState == ENABLE)
   \                     I2C_AcknowledgeConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0003        BNE      ??I2C_AcknowledgeConfig_0
    159            {
    160              I2Cx->CR |= I2C_ACK_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1004        ORRS     R1,R1,#0x4
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x18   0xEA00'0002        B        ??I2C_AcknowledgeConfig_1
    161            }
    162            else
    163            {
    164              I2Cx->CR &= ~I2C_ACK_Mask;
   \                     ??I2C_AcknowledgeConfig_0:
   \       0x1C   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x20   0xE211'10FB        ANDS     R1,R1,#0xFB
   \       0x24   0xE5C0'1000        STRB     R1,[R0, #+0]
    165            }
    166          }
   \                     ??I2C_AcknowledgeConfig_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
    167          
    168          /*******************************************************************************
    169          * Function Name  : I2C_ITConfig
    170          * Description    : Enables or disables I2C interrupt feature.
    171          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    172          *                     I2C0, I2C1
    173          *                  - NewState: specifies the new status to set. It can be:
    174          *                     ENABLE: enables the I2C interrupt feature.
    175          *                     DISABLE: disables the I2C interrupt feature.
    176          * Output         : None.
    177          * Return         : None.
    178          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    179          void I2C_ITConfig (I2C_TypeDef *I2Cx, FunctionalState NewState)
    180          {
    181            if (NewState == ENABLE)
   \                     I2C_ITConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'0003        BNE      ??I2C_ITConfig_0
    182            {
    183              I2Cx->CR |= I2C_ITE_Mask;
   \        0xC   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x10   0xE391'1001        ORRS     R1,R1,#0x1
   \       0x14   0xE5C0'1000        STRB     R1,[R0, #+0]
   \       0x18   0xEA00'0002        B        ??I2C_ITConfig_1
    184            }
    185            else
    186            {
    187              I2Cx->CR &= ~I2C_ITE_Mask;
   \                     ??I2C_ITConfig_0:
   \       0x1C   0xE5D0'1000        LDRB     R1,[R0, #+0]
   \       0x20   0xE211'10FE        ANDS     R1,R1,#0xFE
   \       0x24   0xE5C0'1000        STRB     R1,[R0, #+0]
    188            }
    189          }
   \                     ??I2C_ITConfig_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
    190          
    191          /*******************************************************************************
    192          * Function Name  : I2C_RegisterRead
    193          * Description    : Reads any I2C register and returns its value.
    194          * Input          : - I2Cx: specifies the I2C to read its register, it can be:
    195          *                     I2C0, I2C1
    196          *                  - reg: specifies the register to be read, it can be:
    197          *                     I2C_CR, I2C_SR1, I2C_SR2, I2C_CCR, I2C_OAR1, I2C_OAR2,
    198          *                     I2C_DR, I2C_ECCR
    199          * Output         : None.
    200          * Return         : the value of the register passed as parameter(u8)
    201          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    202          u8 I2C_RegisterRead (I2C_TypeDef *I2Cx, I2C_Registers reg)
    203          {
    204            return (*(u8 *)(*((u32 *)&I2Cx) + reg));
   \                     I2C_RegisterRead:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE091'0000        ADDS     R0,R1,R0
   \        0x8   0xE5D0'0000        LDRB     R0,[R0, #+0]
   \        0xC   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x10   0xE12F'FF1E        BX       LR               ;; return
    205          }
    206          
    207          /*******************************************************************************
    208          * Function Name  : I2C_FlagStatus
    209          * Description    : Checks whether any I2C Flag is set or not.
    210          * Input          : - I2Cx: specifies the I2C to read its flags, it can be:
    211          *                     I2C0, I2C1
    212          *                  - Flag: the flag to be read.
    213          * Output         : None.
    214          * Return         : The specified flag status, it can be:
    215          *                   SET: if the tested flag is set.
    216          *                   RESET: if the tested flag is reset.
    217          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    218          FlagStatus I2C_FlagStatus (I2C_TypeDef *I2Cx, u32 Flag)
    219          {
    220            u16 Flag1 = 0, Flag2 = 0, Flag3 = 0, Tmp = 0;
   \                     I2C_FlagStatus:
   \        0x0   0xE3A0'2000        MOV      R2,#+0
   \        0x4   0xE3A0'2000        MOV      R2,#+0
   \        0x8   0xE3A0'2000        MOV      R2,#+0
   \        0xC   0xE3A0'2000        MOV      R2,#+0
    221          
    222            Flag1 = I2Cx->SR1;
   \       0x10   0xE5D0'2004        LDRB     R2,[R0, #+4]
    223            Flag2 = I2Cx->SR2;
   \       0x14   0xE5D0'3008        LDRB     R3,[R0, #+8]
    224            Flag2 = Flag2<<8;
   \       0x18   0xE1B0'3403        LSLS     R3,R3,#+8
    225            Flag3 = I2Cx->CR;
   \       0x1C   0xE5D0'0000        LDRB     R0,[R0, #+0]
    226          
    227            /* Get all the I2C flags in a unique register*/
    228            Tmp = (((Flag1 | (Flag2)) & I2C_Event_Mask) | (Flag3<<14)); 
   \       0x20   0xE193'2002        ORRS     R2,R3,R2
   \       0x24   0xE1B0'2902        LSLS     R2,R2,#+18
   \       0x28   0xE1B0'0700        LSLS     R0,R0,#+14
   \       0x2C   0xE190'0922        ORRS     R0,R0,R2, LSR #+18
    229            
    230            /* Check the status of the specified I2C flag */
    231            if((Tmp & Flag) != RESET)
   \       0x30   0xE1A0'1801        LSL      R1,R1,#+16
   \       0x34   0xE1B0'1821        LSRS     R1,R1,#+16
   \       0x38   0xE111'0000        TST      R1,R0
   \       0x3C   0x0A00'0001        BEQ      ??I2C_FlagStatus_0
    232            {
    233              /* Return SET if I2C_FLAG is set */
    234              return SET;
   \       0x40   0xE3A0'0001        MOV      R0,#+1
   \       0x44   0xEA00'0000        B        ??I2C_FlagStatus_1
    235            }
    236            else
    237            {
    238              /* Return RESET if I2C_FLAG is reset */
    239              return RESET;
   \                     ??I2C_FlagStatus_0:
   \       0x48   0xE3A0'0000        MOV      R0,#+0
   \                     ??I2C_FlagStatus_1:
   \       0x4C   0xE12F'FF1E        BX       LR               ;; return
    240            }
    241          }
    242          /*******************************************************************************
    243          * Function Name  : I2C_GetLastEvent                                  
    244          * Description    : Gets the last I2Cx event that has occurred.                  
    245          * Input          : - I2Cx: specifies the I2C to read its flags, it can be:
    246          *                     I2C0, I2C1.  
    247          * Output         : None.                          
    248          * Return         : The Last happened Event.                           
    249          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    250          u16 I2C_GetLastEvent(I2C_TypeDef *I2Cx)
    251          {
    252            u16 Flag1 = 0, Flag2 = 0, LastEvent = 0;
   \                     I2C_GetLastEvent:
   \        0x0   0xE3A0'1000        MOV      R1,#+0
   \        0x4   0xE3A0'1000        MOV      R1,#+0
   \        0x8   0xE3A0'1000        MOV      R1,#+0
    253          
    254            Flag1 = I2Cx->SR1;
   \        0xC   0xE5D0'1004        LDRB     R1,[R0, #+4]
    255            Flag2 = I2Cx->SR2;
   \       0x10   0xE5D0'0008        LDRB     R0,[R0, #+8]
    256            Flag2 = Flag2<<8;
   \       0x14   0xE1B0'0400        LSLS     R0,R0,#+8
    257            /* Get the last event value from I2C status register */
    258            LastEvent = (((Flag1 | (Flag2)) & I2C_Event_Mask));
   \       0x18   0xE190'0001        ORRS     R0,R0,R1
   \       0x1C   0xE1B0'0900        LSLS     R0,R0,#+18
