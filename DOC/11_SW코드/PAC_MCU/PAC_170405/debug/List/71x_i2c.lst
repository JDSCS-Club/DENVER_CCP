    263          /*******************************************************************************
    264          * Function Name  : I2C_CheckEvent                                         
    265          * Description    : Checks whether the Last I2C Event is equal to the one passed 
    266          *                  as parameter.                                              
    267          * Input          : - I2Cx: specifies the I2C to read its flags, it can be:
    268          *                     I2C0, I2C1
    269                             - I2C_EVENT: specifies the event to be checked. This parameter
    270          *                    can be one of the following values:
    271          *                         - I2C_EVENT_SLAVE_ADDRESS_MATCHED
    272          *                         - I2C_EVENT_SLAVE_BYTE_RECEIVED
    273          *                         - I2C_EVENT_SLAVE_BYTE_TRANSMITTED
    274          *                         - I2C_EVENT_SLAVE_ACK_FAILURE 
    275          *                         - I2C_EVENT_MASTER_MODE_SELECT
    276          *                         - I2C_EVENT_MASTER_MODE_SELECTED
    277          *                         - I2C_EVENT_MASTER_BYTE_RECEIVED
    278          *                         - I2C_EVENT_MASTER_BYTE_TRANSMITTED
    279          *                         - I2C_EVENT_MASTER_MODE_ADDRESS10
    280          *                         - I2C_EVENT_SLAVE_STOP_DETECTED
    281          * Output         : None                                      
    282          * Return         : An FlagStatus enumuration value:
    283          *                         - SET: Last event is equal to the I2C_Event
    284          *                         - RESET: Last event is different from the I2C_Event        
    285          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    286          FlagStatus I2C_CheckEvent(I2C_TypeDef *I2Cx, u16 I2C_EVENT)
    287          {
   \                     I2C_CheckEvent:
   \        0x0   0xE92D'4010        PUSH     {R4,LR}
   \        0x4   0xE1B0'4001        MOVS     R4,R1
    288            u16  LastEvent = I2C_GetLastEvent(I2Cx);
   \        0x8   0x....'....        BL       I2C_GetLastEvent
    289          
    290            /* Check whether the last event is equal to I2C_EVENT */
    291            if (LastEvent == I2C_EVENT)
   \        0xC   0xE1A0'0800        LSL      R0,R0,#+16
   \       0x10   0xE1B0'0820        LSRS     R0,R0,#+16
   \       0x14   0xE1A0'4804        LSL      R4,R4,#+16
   \       0x18   0xE1B0'4824        LSRS     R4,R4,#+16
   \       0x1C   0xE150'0004        CMP      R0,R4
   \       0x20   0x1A00'0001        BNE      ??I2C_CheckEvent_0
    292            {
    293              /* Return SUCCESS when last event is equal to I2C_EVENT */
    294              return SET;
   \       0x24   0xE3A0'0001        MOV      R0,#+1
   \       0x28   0xEA00'0000        B        ??I2C_CheckEvent_1
    295            }
    296            else
    297            {
    298              /* Return ERROR when last event is different from I2C_EVENT */
    299              return RESET;
   \                     ??I2C_CheckEvent_0:
   \       0x2C   0xE3A0'0000        MOV      R0,#+0
   \                     ??I2C_CheckEvent_1:
   \       0x30   0xE8BD'4010        POP      {R4,LR}
   \       0x34   0xE12F'FF1E        BX       LR               ;; return
    300            }
    301          }
