    554          /*******************************************************************************
    555          * Function Name  : I2C_ByteSend
    556          * Description    : Transmits a single byte.
    557          * Input          : - I2Cx: specifies the I2C which will send the single byte, 
    558          *                    it can be:
    559          *                     I2C0, I2C1
    560          *                  - Data: the byte to be transmitted.
    561          * Output         : None.
    562          * Return         : None.
    563          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    564          void I2C_ByteSend (I2C_TypeDef *I2Cx, u8 Data)
    565          {
    566            /* Write in the DR register the byte to be sent */
    567            I2Cx->DR = Data;
   \                     I2C_ByteSend:
   \        0x0   0xE5C0'1018        STRB     R1,[R0, #+24]
    568          }
   \        0x4   0xE12F'FF1E        BX       LR               ;; return
