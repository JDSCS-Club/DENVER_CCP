   \                                 In section .text, align 4, keep-with-next
    315          void I2C_FlagClear (I2C_TypeDef *I2Cx, u32 Flag, ...)
    316          {
   \                     I2C_FlagClear:
   \        0x0   0xE92D'000E        PUSH     {R1-R3}
   \        0x4   0xE92D'4018        PUSH     {R3,R4,LR}
   \        0x8   0xE1B0'4000        MOVS     R4,R0
    317            u8 Tmp = (u8) * ((u32 *) & Flag + sizeof(Flag));
   \        0xC   0xE59D'001C        LDR      R0,[SP, #+28]
    318          
    319          
    320            /* flags that need a read of the SR2 register to be cleared */
    321            if (Flag == I2C_ADD10 || Flag == I2C_EVF || Flag == I2C_BERR 
    322                || Flag == I2C_ARLO || Flag == I2C_STOPF || Flag == I2C_AF
    323                || Flag == I2C_ENDAD)
