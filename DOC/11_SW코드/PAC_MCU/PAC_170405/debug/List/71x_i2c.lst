   \       0x10   0x....'....        BL       RCCU_FrequencyValue
    440            
    441            /* Test the value of the PCLK1 and affect FR0, FR1 and FR2 of the OAR2
    442             register*/
    443            if (PCLK1 > 5000000)
   \       0x14   0x....'....        LDR      R1,??DataTable2_2  ;; 0x4c4b41
   \       0x18   0xE150'0001        CMP      R0,R1
   \       0x1C   0x3A00'0035        BCC      ??I2C_FCLKConfig_0
    444            {
    445              if (PCLK1 < 10000000)
   \       0x20   0x....'....        LDR      R1,??DataTable2_3  ;; 0x989680
   \       0x24   0xE150'0001        CMP      R0,R1
   \       0x28   0x2A00'0002        BCS      ??I2C_FCLKConfig_1
    446              {
    447                I2Cx->OAR2 |= 0x00;
   \       0x2C   0xE5D4'0014        LDRB     R0,[R4, #+20]
   \       0x30   0xE5C4'0014        STRB     R0,[R4, #+20]
   \       0x34   0xEA00'002F        B        ??I2C_FCLKConfig_0
    448              }
    449              else if (PCLK1 < 16670000)
   \                     ??I2C_FCLKConfig_1:
   \       0x38   0x....'....        LDR      R1,??DataTable2_4  ;; 0xfe5d30
   \       0x3C   0xE150'0001        CMP      R0,R1
   \       0x40   0x2A00'0003        BCS      ??I2C_FCLKConfig_2
    450              {
    451                I2Cx->OAR2 |= 0x20;
   \       0x44   0xE5D4'0014        LDRB     R0,[R4, #+20]
   \       0x48   0xE390'0020        ORRS     R0,R0,#0x20
   \       0x4C   0xE5C4'0014        STRB     R0,[R4, #+20]
   \       0x50   0xEA00'0028        B        ??I2C_FCLKConfig_0
    452              }
    453              else if (PCLK1 < 26670000)
   \                     ??I2C_FCLKConfig_2:
   \       0x54   0x....'....        LDR      R1,??DataTable2_5  ;; 0x196f3b0
   \       0x58   0xE150'0001        CMP      R0,R1
   \       0x5C   0x2A00'0003        BCS      ??I2C_FCLKConfig_3
    454              {
    455                I2Cx->OAR2 |= 0x40;
   \       0x60   0xE5D4'0014        LDRB     R0,[R4, #+20]
   \       0x64   0xE390'0040        ORRS     R0,R0,#0x40
   \       0x68   0xE5C4'0014        STRB     R0,[R4, #+20]
   \       0x6C   0xEA00'0021        B        ??I2C_FCLKConfig_0
    456              }
