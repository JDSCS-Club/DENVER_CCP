   \       0x7C   0x0A00'0004        BEQ      ??I2C_TransmissionStatus_6
   \       0x80   0xE5D0'1008        LDRB     R1,[R0, #+8]
   \       0x84   0xE311'0020        TST      R1,#0x20
   \       0x88   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_6
    615            {
    616              NewState = I2C_TX_ADD_OK;
   \       0x8C   0xE3A0'0005        MOV      R0,#+5
   \       0x90   0xEA00'0008        B        ??I2C_TransmissionStatus_1
    617            }
    618            /* If I2C_TRA and I2C_BTF are both set */  
    619            else if ((I2Cx->SR1 & 0x20) && (I2Cx->SR1 & 0x08))
   \                     ??I2C_TransmissionStatus_6:
   \       0x94   0xE5D0'1004        LDRB     R1,[R0, #+4]
   \       0x98   0xE311'0020        TST      R1,#0x20
   \       0x9C   0x0A00'0004        BEQ      ??I2C_TransmissionStatus_7
   \       0xA0   0xE5D0'0004        LDRB     R0,[R0, #+4]
   \       0xA4   0xE310'0008        TST      R0,#0x8
   \       0xA8   0x0A00'0001        BEQ      ??I2C_TransmissionStatus_7
    620            {
    621              NewState = I2C_TX_DATA_OK;
   \       0xAC   0xE3A0'0006        MOV      R0,#+6
   \       0xB0   0xEA00'0000        B        ??I2C_TransmissionStatus_1
    622            }
    623            else
    624            {
    625              NewState = I2C_TX_ONGOING;
   \                     ??I2C_TransmissionStatus_7:
   \       0xB4   0xE3A0'0007        MOV      R0,#+7
    626            }
    627          
    628            return NewState;
   \                     ??I2C_TransmissionStatus_1:
   \       0xB8   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0xBC   0xE12F'FF1E        BX       LR               ;; return
    629          }
