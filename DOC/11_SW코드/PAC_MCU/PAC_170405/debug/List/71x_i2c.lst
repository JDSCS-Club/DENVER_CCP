   \       0x48   0x....'....        LDR      R1,??DataTable2_1  ;; 0x61a81
   \       0x4C   0xE156'0001        CMP      R6,R1
   \       0x50   0x2A00'0008        BCS      ??I2C_SpeedConfig_1
    392            {
    393              result = ((PCLK1 / Clock) - 9) / 3;
   \       0x54   0xE1B0'1006        MOVS     R1,R6
   \       0x58   0x....'....        BL       __aeabi_uidiv
   \       0x5C   0xE250'0009        SUBS     R0,R0,#+9
   \       0x60   0xE3A0'1003        MOV      R1,#+3
   \       0x64   0x....'....        BL       __aeabi_uidiv
