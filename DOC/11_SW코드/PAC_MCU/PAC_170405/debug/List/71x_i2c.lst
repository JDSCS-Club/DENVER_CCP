   \       0x28   0xE59D'100C        LDR      R1,[SP, #+12]
   \       0x2C   0xE351'0F80        CMP      R1,#+512
   \       0x30   0x0A00'000B        BEQ      ??I2C_FlagClear_0
   \       0x34   0xE59D'100C        LDR      R1,[SP, #+12]
   \       0x38   0xE351'0E40        CMP      R1,#+1024
   \       0x3C   0x0A00'0008        BEQ      ??I2C_FlagClear_0
   \       0x40   0xE59D'100C        LDR      R1,[SP, #+12]
   \       0x44   0xE351'0E80        CMP      R1,#+2048
   \       0x48   0x0A00'0005        BEQ      ??I2C_FlagClear_0
   \       0x4C   0xE59D'100C        LDR      R1,[SP, #+12]
   \       0x50   0xE351'0D40        CMP      R1,#+4096
   \       0x54   0x0A00'0002        BEQ      ??I2C_FlagClear_0
   \       0x58   0xE59D'100C        LDR      R1,[SP, #+12]
