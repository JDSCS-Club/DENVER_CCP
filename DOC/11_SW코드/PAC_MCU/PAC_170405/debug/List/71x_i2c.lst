   \       0x14   0xE351'0040        CMP      R1,#+64
   \       0x18   0x0A00'0011        BEQ      ??I2C_FlagClear_0
   \       0x1C   0xE59D'100C        LDR      R1,[SP, #+12]
   \       0x20   0xE351'0080        CMP      R1,#+128
