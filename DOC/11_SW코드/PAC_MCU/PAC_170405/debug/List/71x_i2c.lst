    480          /*******************************************************************************
    481          * Function Name  : I2C_AddressSend
    482          * Description    : Sends the slave address with which the next communication
    483          *                  will be performed.
    484          * Input          : - I2Cx: specifies the I2C which will send the slave address, 
    485          *                    it can be:
    486          *                     I2C0, I2C1
    487          *                  - Address: indicates the slave address which will be 
    488          *                    transmitted
    489          *                  - Mode: specifies the addressing mode, it can be:
    490          *                     I2C_Mode10, I2C_Mode7
    491          *                  - Direction: specifies the communication direction,
    492          *                    it can be:
    493          *                     I2C_RX, I2C_TX
    494          * Output         : None.
    495          * Return         : None.
    496          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    497          void I2C_AddressSend (I2C_TypeDef *I2Cx, u16 Address, I2C_Addressing Mode,
    498                                I2C_Direction Direction)
    499          {
   \                     I2C_AddressSend:
   \        0x0   0xE92D'4038        PUSH     {R3-R5,LR}
   \        0x4   0xE1B0'4000        MOVS     R4,R0
   \        0x8   0xE1B0'5001        MOVS     R5,R1
    500          
    501            /* If the 10 bit addressing mode is selected */	
    502            if (Mode == I2C_Mode10)
   \        0xC   0xE212'20FF        ANDS     R2,R2,#0xFF      ;; Zero extend
   \       0x10   0xE352'0000        CMP      R2,#+0
   \       0x14   0x1A00'0020        BNE      ??I2C_AddressSend_0
    503            {
    504              /* Update the DR register by generated header */
    505              I2Cx->DR = ((Address >> 7) | 0xF0) & 0xFE;
   \       0x18   0xE1B0'0005        MOVS     R0,R5
   \       0x1C   0xE1A0'0800        LSL      R0,R0,#+16
   \       0x20   0xE1B0'0820        LSRS     R0,R0,#+16
   \       0x24   0xE1B0'03A0        LSRS     R0,R0,#+7
   \       0x28   0xE390'00F0        ORRS     R0,R0,#0xF0
   \       0x2C   0xE210'00FE        ANDS     R0,R0,#0xFE
   \       0x30   0xE5C4'0018        STRB     R0,[R4, #+24]
    506              
    507              /* Wait till I2C_ADD10 flag is set */
    508              while ((I2Cx->SR1 & 0x40) == 0)
   \                     ??I2C_AddressSend_1:
   \       0x34   0xE5D4'0004        LDRB     R0,[R4, #+4]
   \       0x38   0xE310'0040        TST      R0,#0x40
   \       0x3C   0x0AFF'FFFC        BEQ      ??I2C_AddressSend_1
    509              {
    510                /* Wait*/
    511              }
    512              
    513              /* clear I2C_ADD10 flag */
    514              (void)I2Cx->SR2;
   \       0x40   0xE5D4'0008        LDRB     R0,[R4, #+8]
    515              
    516              I2Cx->DR = (u8)Address;
   \       0x44   0xE5C4'5018        STRB     R5,[R4, #+24]
    517              
    518              /* Test on the direction to define the read/write bit */
    519              if (Direction == I2C_RX)
   \       0x48   0xE213'30FF        ANDS     R3,R3,#0xFF      ;; Zero extend
   \       0x4C   0xE353'0000        CMP      R3,#+0
   \       0x50   0x1A00'001A        BNE      ??I2C_AddressSend_2
    520              {
    521                /* Wait till I2C_ENDAD flag is set */
    522                while ((I2Cx->SR2 & 0x20) == 0)
   \                     ??I2C_AddressSend_3:
   \       0x54   0xE5D4'0008        LDRB     R0,[R4, #+8]
   \       0x58   0xE310'0020        TST      R0,#0x20
   \       0x5C   0x0AFF'FFFC        BEQ      ??I2C_AddressSend_3
    523                {
    524                  /* Wait*/
    525                }
    526                
    527                I2Cx->CR |= 0x20;
   \       0x60   0xE5D4'0000        LDRB     R0,[R4, #+0]
   \       0x64   0xE390'0020        ORRS     R0,R0,#0x20
   \       0x68   0xE5C4'0000        STRB     R0,[R4, #+0]
    528                
    529                /* Repeated START Generate */
    530                I2C_STARTGenerate (I2Cx, ENABLE);
   \       0x6C   0xE3A0'1001        MOV      R1,#+1
   \       0x70   0xE1B0'0004        MOVS     R0,R4
   \       0x74   0x....'....        BL       I2C_STARTGenerate
    531                
    532                /* Test on SB flag status */
    533                while ((I2Cx->SR1 & 0x01) == 0)
   \                     ??I2C_AddressSend_4:
   \       0x78   0xE5D4'0004        LDRB     R0,[R4, #+4]
   \       0x7C   0xE310'0001        TST      R0,#0x1
   \       0x80   0x0AFF'FFFC        BEQ      ??I2C_AddressSend_4
    534                {
    535                }
    536                I2Cx->DR = ((Address >> 7) | 0xF1);
   \       0x84   0xE1A0'5805        LSL      R5,R5,#+16
   \       0x88   0xE1B0'5825        LSRS     R5,R5,#+16
   \       0x8C   0xE1B0'03A5        LSRS     R0,R5,#+7
   \       0x90   0xE390'00F1        ORRS     R0,R0,#0xF1
   \       0x94   0xE5C4'0018        STRB     R0,[R4, #+24]
   \       0x98   0xEA00'0008        B        ??I2C_AddressSend_2
    537              }
    538            }
    539            /* If the 7 bit addressing mode is selected */
    540            else
    541            {
    542              if (Direction == I2C_RX)
   \                     ??I2C_AddressSend_0:
   \       0x9C   0xE213'30FF        ANDS     R3,R3,#0xFF      ;; Zero extend
   \       0xA0   0xE353'0000        CMP      R3,#+0
   \       0xA4   0x1A00'0001        BNE      ??I2C_AddressSend_5
    543              {
    544                Address |= 0x01;
   \       0xA8   0xE395'0001        ORRS     R0,R5,#0x1
   \       0xAC   0xEA00'0002        B        ??I2C_AddressSend_6
    545              }
    546              else
    547              {
    548                Address &= ~0x01;
   \                     ??I2C_AddressSend_5:
   \       0xB0   0xE3A0'00FE        MOV      R0,#+254
   \       0xB4   0xE380'0CFF        ORR      R0,R0,#0xFF00
   \       0xB8   0xE010'0005        ANDS     R0,R0,R5
    549              }
    550              I2Cx->DR = (u8)Address;
   \                     ??I2C_AddressSend_6:
   \       0xBC   0xE5C4'0018        STRB     R0,[R4, #+24]
    551            }
    552          }
   \                     ??I2C_AddressSend_2:
   \       0xC0   0xE8BD'4031        POP      {R0,R4,R5,LR}
   \       0xC4   0xE12F'FF1E        BX       LR               ;; return
