   \                                 In section .text, align 4, keep-with-next
    434          void I2C_FCLKConfig (I2C_TypeDef *I2Cx)
    435          {
   \                     I2C_FCLKConfig:
   \        0x0   0xE92D'4010        PUSH     {R4,LR}
   \        0x4   0xE1B0'4000        MOVS     R4,R0
    436            u32 PCLK1 = 0;
