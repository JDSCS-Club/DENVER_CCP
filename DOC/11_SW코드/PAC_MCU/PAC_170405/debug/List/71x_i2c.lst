    363          /*******************************************************************************
    364          * Function Name  : I2C_SpeedConfig
    365          * Description    : Selects I2C clock speed and configures its corresponding mode
    366          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    367          *                     I2C0, I2C1
    368          *                  - Clock: the I2C expected clock in Hertz.
    369          * Output         : None.
    370          * Return         : None.
    371          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    372          void I2C_SpeedConfig (I2C_TypeDef *I2Cx, u32 Clock)
    373          {
   \                     I2C_SpeedConfig:
   \        0x0   0xE92D'4070        PUSH     {R4-R6,LR}
   \        0x4   0xE1B0'4000        MOVS     R4,R0
   \        0x8   0xE1B0'6001        MOVS     R6,R1
    374            u32 PCLK1 = 0;
   \        0xC   0xE3A0'0000        MOV      R0,#+0
    375            u16 result = 0;
   \       0x10   0xE3A0'5000        MOV      R5,#+0
    376            
    377            /* Get the FCLK frequency using the RCCU library */
    378            PCLK1 = RCCU_FrequencyValue (RCCU_PCLK1);
   \       0x14   0xE3A0'0004        MOV      R0,#+4
   \       0x18   0x....'....        BL       RCCU_FrequencyValue
    379            
    380            /* Test on speed mode */
    381            /* Update the CCR and ECCR registers */
    382          
    383            /* If Standard mode is selected */
    384            if (Clock <= 100000)
   \       0x1C   0x....'....        LDR      R1,??DataTable2  ;; 0x186a1
   \       0x20   0xE156'0001        CMP      R6,R1
   \       0x24   0x2A00'0007        BCS      ??I2C_SpeedConfig_0
    385            {
    386              result = ((PCLK1 / Clock) - 7) / 2;
   \       0x28   0xE1B0'1006        MOVS     R1,R6
   \       0x2C   0x....'....        BL       __aeabi_uidiv
   \       0x30   0xE250'0007        SUBS     R0,R0,#+7
   \       0x34   0xE1B0'50A0        LSRS     R5,R0,#+1
    387              /* Clear FM/SM bit */
    388              I2Cx->CCR = result & 0x7f;
   \       0x38   0xE1B0'0005        MOVS     R0,R5
   \       0x3C   0xE210'007F        ANDS     R0,R0,#0x7F
   \       0x40   0xE5C4'000C        STRB     R0,[R4, #+12]
   \       0x44   0xEA00'000B        B        ??I2C_SpeedConfig_1
    389            }
    390           /* If Fast mode is selected */
    391            else if (Clock <= 400000)
