   \       0xD0   0xE351'0001        CMP      R1,#+1
   \       0xD4   0x1A00'0001        BNE      ??I2C_FlagClear_7
    347              {
    348                I2Cx->DR = Tmp;
   \       0xD8   0xE5C4'0018        STRB     R0,[R4, #+24]
