   \       0x7C   0xE1B0'5825        LSRS     R5,R5,#+16
   \       0x80   0xE1B0'03A5        LSRS     R0,R5,#+7
   \       0x84   0xE5C4'001C        STRB     R0,[R4, #+28]
    399          }
   \       0x88   0xE8BD'4070        POP      {R4-R6,LR}
   \       0x8C   0xE12F'FF1E        BX       LR               ;; return
    400          
    401          /*******************************************************************************
    402          * Function Name  : I2C_AddressConfig
    403          * Description    : Defines the I2C bus address of the interface.
    404          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    405          *                     I2C0, I2C1
    406          *                  - Address: an u16 parameter indicating the interface
    407          *                    address.
    408          *                  - Mode: specifies the addressing mode, it can be:
    409          *                     I2C_Mode7, I2C_Mode10
    410          * Output         : None.
    411          * Return         : None.
    412          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    413          void I2C_AddressConfig (I2C_TypeDef *I2Cx, u16 Address, I2C_Addressing Mode)
    414          {
    415            /* Update OAR1 bit[7:1] by the lowest byte of address */
    416            I2Cx->OAR1 = (u8)Address;
   \                     I2C_AddressConfig:
   \        0x0   0xE5C0'1010        STRB     R1,[R0, #+16]
    417          
    418            if (Mode == I2C_Mode10)
   \        0x4   0xE212'20FF        ANDS     R2,R2,#0xFF      ;; Zero extend
   \        0x8   0xE352'0000        CMP      R2,#+0
   \        0xC   0x1A00'0006        BNE      ??I2C_AddressConfig_0
    419            {
    420              /* Update Add8 and add9 bits in OAR2 */
    421              I2Cx->OAR2 |= (Address & 0x0300) >> 7;
