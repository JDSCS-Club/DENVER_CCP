   \       0x14   0xE1A0'1801        LSL      R1,R1,#+16
   \       0x18   0xE1B0'1821        LSRS     R1,R1,#+16
   \       0x1C   0xE1B0'13C1        ASRS     R1,R1,#+7
   \       0x20   0xE211'1006        ANDS     R1,R1,#0x6
   \       0x24   0xE191'1002        ORRS     R1,R1,R2
   \       0x28   0xE5C0'1014        STRB     R1,[R0, #+20]
    422            }
    423          }
   \                     ??I2C_AddressConfig_0:
   \       0x2C   0xE12F'FF1E        BX       LR               ;; return
    424          
    425          /*******************************************************************************
    426          * Function Name  : I2C_FCLKConfig
    427          * Description    : Configures I2C frequency bits according to PCLK1 frequency.
    428          *                  The selected I2C must be disabled.
    429          * Input          : - I2Cx: specifies the I2C to be configured, it can be:
    430          *                     I2C0, I2C1
    431          * Output         : None.
