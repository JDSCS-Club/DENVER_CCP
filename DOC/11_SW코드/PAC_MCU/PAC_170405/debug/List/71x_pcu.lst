     49          /*******************************************************************************
     50          * Function Name  : PCU_FlagStatus
     51          * Description    : This routine is used to return the PCU register flag
     52          * Input          : - Xflag: the flag to get the status.
     53          * Output         : None.
     54          * Return         : the status of the flag passed in parameter, it can be: 
     55          *                  SET or RESET 
     56          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     57          FlagStatus PCU_FlagStatus (PCU_Flags Xflag)
     58          {
     59            if ((PCU->PWRCR & Xflag) == 0x00)
   \                     PCU_FlagStatus:
   \        0x0   0xE3A0'1054        MOV      R1,#+84
   \        0x4   0xE381'14A0        ORR      R1,R1,#0xA0000000
   \        0x8   0xE1D1'10B0        LDRH     R1,[R1, #+0]
   \        0xC   0xE1A0'0800        LSL      R0,R0,#+16
   \       0x10   0xE1B0'0820        LSRS     R0,R0,#+16
   \       0x14   0xE110'0001        TST      R0,R1
   \       0x18   0x1A00'0001        BNE      ??PCU_FlagStatus_0
     60            {
     61              return RESET;	
   \       0x1C   0xE3A0'0000        MOV      R0,#+0
   \       0x20   0xEA00'0000        B        ??PCU_FlagStatus_1
     62            }
     63            else
     64            {
     65              return SET;	
   \                     ??PCU_FlagStatus_0:
   \       0x24   0xE3A0'0001        MOV      R0,#+1
   \                     ??PCU_FlagStatus_1:
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
     66            }
     67          }
