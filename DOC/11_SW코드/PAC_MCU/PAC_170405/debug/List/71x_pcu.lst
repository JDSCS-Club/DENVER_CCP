    190          /*******************************************************************************
    191          * Function Name  : PCU_LPModesConfig
    192          * Description    : This routine is used to configure the different STR71x
    193          *                  low power modes options
    194          * Input          : - PLL1_State: the state of PLL1 when CK_AF selected.It can be:
    195          *                     ENABLE : PLL1 is not disabled when CK_AF is selected.
    196          *                     DISABLE: PLL1 is disabled automaticaty when CK_AF 
    197          *                     is selected as system clock.
    198          *                  - MVR_State: the state of the Main Voltage Regulator when 
    199          *                    CK_AF is selected. It can be:
    200          *                     ENABLE : MVREG is enabled during LPWFI and STOP modes
    201          *                     DISABLE: MVREG is disabled during LPWFI and STOP modes
    202          *                  - FLASH_State: the state of the flash during LPWFI and STOP
    203          *                    modes. It can be:
    204          *                     ENABLE : Flash Stand-by mode during LPWFI and STOP modes
    205          *                     DISABLE: FLASH in powerdown during LPWFI and STOP modes
    206          *                  - LPWFI_State: the state of low power mode during LPWFI.
    207          *                    It can be:
    208          *                     ENABLE : Enable Low power mode during WFI mode (LPWFI)
    209          *                     DISABLE: Disable Low power modeduring WFI mode (WFI).
    210          *                  - LPWFI_Clock: the selected clock during LPWFI. It can be:
    211                                LPWFI_CLK2_16: CLK2/16 is selected during LPWFI.
    212          *                     LPWFI_CK_AF  : CK_AF is selected during LPWFI.
    213          * Output         : None.
    214          * Return         : None.
    215          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    216          void PCU_LPModesConfig (FunctionalState PLL1_State, FunctionalState MVR_State,
    217                                 FunctionalState FLASH_State, FunctionalState LPWFI_State,
    218                                 LPWFI_Clock_Typedef LPWFI_Clock)
    219          {
    220          
    221            /* Configure if the PLL1 is disabled automatically when CK_AF is selected
    222             as system clock */
    223            if (PLL1_State == DISABLE)
   \                     PCU_LPModesConfig:
   \        0x0   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \        0x4   0xE350'0000        CMP      R0,#+0
   \        0x8   0x1A00'0004        BNE      ??PCU_LPModesConfig_0
    224            {
    225              /* PLL1 is disabled when CK_AF is selected */
    226              RCCU->CFR |= 1 << 4;
   \        0xC   0xE3A0'028A        MOV      R0,#-1610612728
   \       0x10   0xE590'C000        LDR      R12,[R0, #+0]
   \       0x14   0xE39C'C010        ORRS     R12,R12,#0x10
   \       0x18   0xE580'C000        STR      R12,[R0, #+0]
   \       0x1C   0xEA00'0003        B        ??PCU_LPModesConfig_1
    227            }
    228            else
    229            {
    230              /* PLL1 is not disabled when CK_AF is selected */
    231              RCCU->CFR &= ~(1 << 4);
   \                     ??PCU_LPModesConfig_0:
   \       0x20   0xE3A0'028A        MOV      R0,#-1610612728
   \       0x24   0xE590'C000        LDR      R12,[R0, #+0]
   \       0x28   0xE3DC'C010        BICS     R12,R12,#0x10
   \       0x2C   0xE580'C000        STR      R12,[R0, #+0]
    232            }
    233          
    234            /* Configure the MVREG state during LPWFI and STOP modes */
    235            if (MVR_State == DISABLE)
   \                     ??PCU_LPModesConfig_1:
   \       0x30   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \       0x34   0xE351'0000        CMP      R1,#+0
   \       0x38   0x1A00'0009        BNE      ??PCU_LPModesConfig_2
    236            {
    237              /* MVREG is disabled during LPWFI and STOP modes */
    238              /*  Unlock Power Control Register */
    239              PCU->PWRCR |= PCU_WREN_Mask;
   \       0x3C   0xE3A0'0054        MOV      R0,#+84
   \       0x40   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \       0x44   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x48   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x4C   0xE1C0'10B0        STRH     R1,[R0, #+0]
    240              PCU->PWRCR |= PCU_LPRWFI_Mask | PCU_WREN_Mask;
   \       0x50   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x54   0xE391'1010        ORRS     R1,R1,#0x10
   \       0x58   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x5C   0xE1C0'10B0        STRH     R1,[R0, #+0]
   \       0x60   0xEA00'0009        B        ??PCU_LPModesConfig_3
    241            }
    242            else
    243            {
    244              /* MVREG is enabled during LPWFI and STOP modes */
    245              /*  Unlock Power Control Register */
    246              PCU->PWRCR |= PCU_WREN_Mask;
   \                     ??PCU_LPModesConfig_2:
   \       0x64   0xE3A0'0054        MOV      R0,#+84
   \       0x68   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \       0x6C   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x70   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x74   0xE1C0'10B0        STRH     R1,[R0, #+0]
    247              PCU->PWRCR &= (~(1 << 4)) | PCU_WREN_Mask;
   \       0x78   0xE1D0'10B0        LDRH     R1,[R0, #+0]
