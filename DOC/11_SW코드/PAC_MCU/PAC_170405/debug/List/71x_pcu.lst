     69          /*******************************************************************************
     70          * Function Name  : PCU_VRConfig
     71          * Description    : This routine is used to configure PCU voltage regultors.
     72          * Input          : - Xvr: Specifies the PCU voltage regulator, it can be:
     73          *                     PCU_MVR : Main voltage Regulator
     74          *                     PCU_LPR : Low Power Regulator
     75          *                : - NewState: Specifies whatever the corresponding voltage 
     76          *                    regulator is enabled or bypassed, it can be:
     77          *                     ENABLE : Enable the Voltage Regulator.
     78          *                     DISABLE: Disable ( ByPass ) the VR.
     79          * Output         : None.
     80          * Return         : None.
     81          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     82          void PCU_VRConfig (PCU_VR Xvr, FunctionalState NewState)
     83          {
   \                     PCU_VRConfig:
   \        0x0   0xE24D'D004        SUB      SP,SP,#+4
     84            vu16 Tmp = PCU->PWRCR;
   \        0x4   0xE3A0'2054        MOV      R2,#+84
   \        0x8   0xE382'24A0        ORR      R2,R2,#0xA0000000
   \        0xC   0xE1D2'30B0        LDRH     R3,[R2, #+0]
   \       0x10   0xE1CD'30B0        STRH     R3,[SP, #+0]
     85            
     86            switch (Xvr)
   \       0x14   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x18   0xE350'0008        CMP      R0,#+8
   \       0x1C   0x0A00'0002        BEQ      ??PCU_VRConfig_0
   \       0x20   0xE350'0010        CMP      R0,#+16
   \       0x24   0x0A00'000D        BEQ      ??PCU_VRConfig_1
   \       0x28   0xEA00'0018        B        ??PCU_VRConfig_2
     87            {
     88              case PCU_MVR :
     89                /* Configure the Main Voltage Regulator */
     90                if (NewState == DISABLE)
   \                     ??PCU_VRConfig_0:
   \       0x2C   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \       0x30   0xE351'0000        CMP      R1,#+0
   \       0x34   0x1A00'0003        BNE      ??PCU_VRConfig_3
     91                {
     92                  Tmp |= PCU_VRBYP_Mask;
   \       0x38   0xE1DD'00B0        LDRH     R0,[SP, #+0]
   \       0x3C   0xE390'0008        ORRS     R0,R0,#0x8
   \       0x40   0xE1CD'00B0        STRH     R0,[SP, #+0]
   \       0x44   0xEA00'0004        B        ??PCU_VRConfig_4
     93                }
     94                else
     95                {
     96                  Tmp &= ~PCU_VRBYP_Mask;
   \                     ??PCU_VRConfig_3:
   \       0x48   0xE1DD'00B0        LDRH     R0,[SP, #+0]
   \       0x4C   0xE3A0'10F7        MOV      R1,#+247
   \       0x50   0xE381'1CFF        ORR      R1,R1,#0xFF00
   \       0x54   0xE011'0000        ANDS     R0,R1,R0
   \       0x58   0xE1CD'00B0        STRH     R0,[SP, #+0]
     97                }
     98                break;
   \                     ??PCU_VRConfig_4:
   \       0x5C   0xEA00'000B        B        ??PCU_VRConfig_2
     99                
    100              case PCU_LPR :
    101                /* Configure the Low power Voltage Regulator */
    102                if (NewState == DISABLE)
   \                     ??PCU_VRConfig_1:
   \       0x60   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \       0x64   0xE351'0000        CMP      R1,#+0
   \       0x68   0x1A00'0003        BNE      ??PCU_VRConfig_5
    103                {
    104                  Tmp |= PCU_LPRWFI_Mask;
   \       0x6C   0xE1DD'00B0        LDRH     R0,[SP, #+0]
   \       0x70   0xE390'0010        ORRS     R0,R0,#0x10
   \       0x74   0xE1CD'00B0        STRH     R0,[SP, #+0]
   \       0x78   0xEA00'0004        B        ??PCU_VRConfig_6
    105                }
    106                else
    107                {
    108                  Tmp &= ~PCU_LPRWFI_Mask;
   \                     ??PCU_VRConfig_5:
   \       0x7C   0xE1DD'00B0        LDRH     R0,[SP, #+0]
   \       0x80   0xE3A0'10EF        MOV      R1,#+239
   \       0x84   0xE381'1CFF        ORR      R1,R1,#0xFF00
   \       0x88   0xE011'0000        ANDS     R0,R1,R0
   \       0x8C   0xE1CD'00B0        STRH     R0,[SP, #+0]
    109                }
    110                break;
    111            }
    112          
    113            while ((PCU->PWRCR & PCU_BUSY_Mask) == 1)
   \                     ??PCU_VRConfig_6:
   \                     ??PCU_VRConfig_2:
   \       0x90   0xE1D2'00B0        LDRH     R0,[R2, #+0]
    114            {
    115              /* Wait until the previous write operation is completed */
    116            }
    117          
    118            /*  Unlock Power Control Register */
    119            PCU->PWRCR |= PCU_WREN_Mask;
   \       0x94   0xE1D2'00B0        LDRH     R0,[R2, #+0]
   \       0x98   0xE390'0C80        ORRS     R0,R0,#0x8000
   \       0x9C   0xE1C2'00B0        STRH     R0,[R2, #+0]
    120            PCU->PWRCR = Tmp | PCU_WREN_Mask;
   \       0xA0   0xE1DD'00B0        LDRH     R0,[SP, #+0]
   \       0xA4   0xE390'0C80        ORRS     R0,R0,#0x8000
   \       0xA8   0xE1C2'00B0        STRH     R0,[R2, #+0]
    121          }
   \       0xAC   0xE28D'D004        ADD      SP,SP,#+4
   \       0xB0   0xE12F'FF1E        BX       LR               ;; return
    122          
    123          /*******************************************************************************
    124          * Function Name  : PCU_LVDDisable
    125          * Description    : This routine is used to disable the Low Voltage Detector.
    126          * Input          : None.
    127          * Output         : None.
    128          * Return         : None.
    129          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    130          void PCU_LVDDisable (void)
    131          {
    132            
    133            while ((PCU->PWRCR & PCU_BUSY_Mask) == 1)
   \                     PCU_LVDDisable:
   \        0x0   0xE3A0'0054        MOV      R0,#+84
   \        0x4   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \        0x8   0xE1D0'10B0        LDRH     R1,[R0, #+0]
    134            {
    135              /* Wait until the previous write operation will be completed */
    136            }
    137          
    138            /*  Unlock Power Control Register */
    139            PCU->PWRCR |= PCU_WREN_Mask;
   \        0xC   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x10   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x14   0xE1C0'10B0        STRH     R1,[R0, #+0]
    140          
    141            /*  Set the LVD DIS Flag */
    142            PCU->PWRCR |= PCU_LVD_DIS_Mask;
   \       0x18   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x1C   0xE391'1F40        ORRS     R1,R1,#0x100
   \       0x20   0xE1C0'10B0        STRH     R1,[R0, #+0]
    143          }
   \       0x24   0xE12F'FF1E        BX       LR               ;; return
    144          
    145          /*******************************************************************************
    146          * Function Name  : PCU_VRStatus
    147          * Description    : This routine is used to get the PCU voltage regultors status.
    148          * Input          : - xVR: the voltage regulator to get its status, it can be:
    149          *                     PCU_MVR : Main voltage Regulator.
    150          *                     PCU_LPR : Low Power Regulator.
    151          * Output         : None.
    152          * Return         : the status of the voltage regulator passed in parameter.
    153          *                  It can be:
    154          *                   ENABLE : the Voltage Regulator is enabled.
    155          *                   DISABLE: the Voltage Regulator is passed.
    156          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    157          FunctionalState PCU_VRStatus (PCU_VR xVR)
    158          {
    159            if ((PCU->PWRCR & xVR) == 0)
   \                     PCU_VRStatus:
   \        0x0   0xE3A0'1054        MOV      R1,#+84
   \        0x4   0xE381'14A0        ORR      R1,R1,#0xA0000000
   \        0x8   0xE1D1'10B0        LDRH     R1,[R1, #+0]
   \        0xC   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x10   0xE110'0001        TST      R0,R1
   \       0x14   0x1A00'0001        BNE      ??PCU_VRStatus_0
    160            {
    161              return ENABLE;	
   \       0x18   0xE3A0'0001        MOV      R0,#+1
   \       0x1C   0xEA00'0000        B        ??PCU_VRStatus_1
    162            }
    163            else
    164            {
    165              return DISABLE;
   \                     ??PCU_VRStatus_0:
   \       0x20   0xE3A0'0000        MOV      R0,#+0
   \                     ??PCU_VRStatus_1:
   \       0x24   0xE12F'FF1E        BX       LR               ;; return
    166            }	
    167          }
    168          
    169          /*******************************************************************************
    170          * Function Name  : PCU_LVDStatus
    171          * Description    : This routine is used to get and return the LVD status.
    172          * Input          : None.
    173          * Output         : None.
    174          * Return         : The LVD status, it can be:
    175          *                   ENABLE: the LVD is enabled.
    176          *                   DISABLE: the LVD is disabled.
    177          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    178          FunctionalState PCU_LVDStatus (void)
    179          {
    180            if ((PCU->PWRCR & PCU_LVD_DIS_Mask) == 0)
   \                     PCU_LVDStatus:
   \        0x0   0xE3A0'0054        MOV      R0,#+84
   \        0x4   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \        0x8   0xE1D0'00B0        LDRH     R0,[R0, #+0]
   \        0xC   0xE310'0F40        TST      R0,#0x100
   \       0x10   0x1A00'0001        BNE      ??PCU_LVDStatus_0
    181            {
    182              return ENABLE;
   \       0x14   0xE3A0'0001        MOV      R0,#+1
   \       0x18   0xEA00'0000        B        ??PCU_LVDStatus_1
    183            }	
    184            else
    185            {
    186              return DISABLE;
   \                     ??PCU_LVDStatus_0:
   \       0x1C   0xE3A0'0000        MOV      R0,#+0
   \                     ??PCU_LVDStatus_1:
   \       0x20   0xE12F'FF1E        BX       LR               ;; return
    187            }
    188          }
