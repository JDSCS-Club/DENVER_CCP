     27          /*******************************************************************************
     28          * Function Name  : PCU_MVRStatus
     29          * Description    : This routine is used to check and return the Main Voltage 
     30          *                  Regulator stability status.
     31          * Input          : None.
     32          * Output         : None.
     33          * Return         : The stability status of the Main Voltage Regulator,
     34          *                  it can be:
     35          *                   STABLE, UNSTABLE
     36          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     37          PCU_VR_Status PCU_MVRStatus (void)
     38          {
     39            if ((PCU->PWRCR & PCU_VROK_Mask) == 0x00)
   \                     PCU_MVRStatus:
   \        0x0   0xE3A0'0054        MOV      R0,#+84
   \        0x4   0xE380'04A0        ORR      R0,R0,#0xA0000000
   \        0x8   0xE1D0'00B0        LDRH     R0,[R0, #+0]
   \        0xC   0xE310'0D40        TST      R0,#0x1000
   \       0x10   0x1A00'0001        BNE      ??PCU_MVRStatus_0
     40            {
     41              return PCU_UNSTABLE;
   \       0x14   0xE3A0'0001        MOV      R0,#+1
   \       0x18   0xEA00'0000        B        ??PCU_MVRStatus_1
     42            }
     43           else
     44            {
     45              return PCU_STABLE;
   \                     ??PCU_MVRStatus_0:
   \       0x1C   0xE3A0'0000        MOV      R0,#+0
   \                     ??PCU_MVRStatus_1:
   \       0x20   0xE12F'FF1E        BX       LR               ;; return
     46            }
     47          }
