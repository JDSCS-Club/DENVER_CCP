   \        0x8   0xE5C1'0000        STRB     R0,[R1, #+0]
     41            XTI->MRH = 0x00;
   \        0xC   0x....'....        LDR      R1,??DataTable6_1  ;; 0xe0001028
   \       0x10   0xE5C1'0000        STRB     R0,[R1, #+0]
     42            XTI->MRL = 0x00;
   \       0x14   0x....'....        LDR      R1,??DataTable6_2  ;; 0xe000102c
   \       0x18   0xE5C1'0000        STRB     R0,[R1, #+0]
     43            XTI->TRH = 0x00;
   \       0x1C   0x....'....        LDR      R1,??DataTable6_3  ;; 0xe0001030
   \       0x20   0xE5C1'0000        STRB     R0,[R1, #+0]
     44            XTI->TRL = 0x00;
   \       0x24   0x....'....        LDR      R1,??DataTable6_4  ;; 0xe0001034
   \       0x28   0xE5C1'0000        STRB     R0,[R1, #+0]
     45            XTI->PRH = 0x00;
   \       0x2C   0x....'....        LDR      R1,??DataTable6_5  ;; 0xe0001038
   \       0x30   0xE5C1'0000        STRB     R0,[R1, #+0]
     46            XTI->PRL = 0x00;
   \       0x34   0x....'....        LDR      R1,??DataTable6_6  ;; 0xe000103c
   \       0x38   0xE5C1'0000        STRB     R0,[R1, #+0]
     47            
     48            /* Write the STOP bit twice to reset the STOP state machine */
     49            XTI->CTRL = 0x00;
   \       0x3C   0x....'....        LDR      R1,??DataTable6_7  ;; 0xe0001024
   \       0x40   0xE5C1'0000        STRB     R0,[R1, #+0]
     50            XTI->CTRL = 0x00;
