   \        0x4   0xE3A0'124E        MOV      R1,#-536870908
   \        0x8   0xE381'1CE0        ORR      R1,R1,#0xE000
   \        0xC   0xE1C1'00B0        STRH     R0,[R1, #+0]
     65          }
   \       0x10   0xE12F'FF1E        BX       LR               ;; return
