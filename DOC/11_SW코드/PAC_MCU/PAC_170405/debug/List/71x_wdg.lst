    167          /*******************************************************************************
    168          * Function Name  : FindFactors
    169          * Description    : Searchs for the best (a,b) values that fit n = a*b
    170          *                  with the following constraints: 1<=a<=256, 1<=b<=65536
    171          * Input          : - n: the number to decompose.
    172          * Output         : - a: a pointer to the first factor.
    173          *                  - b: a pointer to the second factor.
    174          * Return         : None.
    175          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    176          static void FindFactors(u32 n, u16 *a, u32 *b)
    177          {
   \                     FindFactors:
   \        0x0   0xE92D'4FF8        PUSH     {R3-R11,LR}
   \        0x4   0xE1B0'4000        MOVS     R4,R0
   \        0x8   0xE1B0'5001        MOVS     R5,R1
   \        0xC   0xE1B0'6002        MOVS     R6,R2
    178            u32 b0;
    179            u16 a0;
    180            long err, err_min = n;
   \       0x10   0xE1B0'7004        MOVS     R7,R4
    181          
    182            *a = a0 = ((n - 1) / 65536ul) + 1;
   \       0x14   0xE254'0001        SUBS     R0,R4,#+1
   \       0x18   0xE3A0'1001        MOV      R1,#+1
   \       0x1C   0xE091'8820        ADDS     R8,R1,R0, LSR #+16
   \       0x20   0xE1C5'80B0        STRH     R8,[R5, #+0]
    183            *b = b0 = n / *a;
   \       0x24   0xE1B0'0004        MOVS     R0,R4
   \       0x28   0xE1D5'10B0        LDRH     R1,[R5, #+0]
   \       0x2C   0x....'....        BL       __aeabi_uidiv
   \       0x30   0xE1B0'9000        MOVS     R9,R0
   \       0x34   0xE586'9000        STR      R9,[R6, #+0]
   \       0x38   0xEA00'0002        B        ??FindFactors_0
    184          
    185            for (; *a <= 256; (*a)++)
   \                     ??FindFactors_1:
   \       0x3C   0xE1D5'00B0        LDRH     R0,[R5, #+0]
   \       0x40   0xE290'0001        ADDS     R0,R0,#+1
   \       0x44   0xE1C5'00B0        STRH     R0,[R5, #+0]
   \                     ??FindFactors_0:
   \       0x48   0xE1D5'00B0        LDRH     R0,[R5, #+0]
   \       0x4C   0xE3A0'1001        MOV      R1,#+1
   \       0x50   0xE381'1F40        ORR      R1,R1,#0x100
   \       0x54   0xE150'0001        CMP      R0,R1
   \       0x58   0xAA00'0022        BGE      ??FindFactors_2
    186            {
    187              *b = n / *a;
   \       0x5C   0xE1B0'0004        MOVS     R0,R4
   \       0x60   0xE1D5'10B0        LDRH     R1,[R5, #+0]
   \       0x64   0x....'....        BL       __aeabi_uidiv
   \       0x68   0xE586'0000        STR      R0,[R6, #+0]
    188              err = (long) * a * (long) * b - (long)n;
   \       0x6C   0xE1D5'00B0        LDRH     R0,[R5, #+0]
   \       0x70   0xE596'1000        LDR      R1,[R6, #+0]
   \       0x74   0xE010'0091        MULS     R0,R1,R0
   \       0x78   0xE050'A004        SUBS     R10,R0,R4
    189              if (abs_value(err) > (*a / 2))
   \       0x7C   0xE1B0'000A        MOVS     R0,R10
   \       0x80   0x....'....        BL       abs_value
   \       0x84   0xE1B0'B000        MOVS     R11,R0
   \       0x88   0xE1D5'00B0        LDRH     R0,[R5, #+0]
   \       0x8C   0xE3A0'1002        MOV      R1,#+2
   \       0x90   0x....'....        BL       __aeabi_idiv
   \       0x94   0xE150'000B        CMP      R0,R11
   \       0x98   0xAA00'0006        BGE      ??FindFactors_3
    190              {
    191                (*b)++;
   \       0x9C   0xE596'0000        LDR      R0,[R6, #+0]
   \       0xA0   0xE290'0001        ADDS     R0,R0,#+1
   \       0xA4   0xE586'0000        STR      R0,[R6, #+0]
    192                err = (long) * a * (long) * b - (long)n;
   \       0xA8   0xE1D5'00B0        LDRH     R0,[R5, #+0]
   \       0xAC   0xE596'1000        LDR      R1,[R6, #+0]
   \       0xB0   0xE010'0091        MULS     R0,R1,R0
   \       0xB4   0xE050'A004        SUBS     R10,R0,R4
    193              }
    194              if (abs_value(err) < abs_value(err_min))
   \                     ??FindFactors_3:
   \       0xB8   0xE1B0'000A        MOVS     R0,R10
   \       0xBC   0x....'....        BL       abs_value
   \       0xC0   0xE1B0'B000        MOVS     R11,R0
   \       0xC4   0xE1B0'0007        MOVS     R0,R7
   \       0xC8   0x....'....        BL       abs_value
   \       0xCC   0xE15B'0000        CMP      R11,R0
   \       0xD0   0xAAFF'FFD9        BGE      ??FindFactors_1
    195              {
    196                err_min = err;
   \       0xD4   0xE1B0'700A        MOVS     R7,R10
    197                a0 = *a;
   \       0xD8   0xE1D5'80B0        LDRH     R8,[R5, #+0]
    198                b0 = *b;
   \       0xDC   0xE596'9000        LDR      R9,[R6, #+0]
    199                if (err == 0)
   \       0xE0   0xE35A'0000        CMP      R10,#+0
   \       0xE4   0x1AFF'FFD4        BNE      ??FindFactors_1
    200                {
    201                  break;
    202                }
    203              }
    204            }
    205          
    206            *a = a0;
   \                     ??FindFactors_2:
   \       0xE8   0xE1C5'80B0        STRH     R8,[R5, #+0]
    207            *b = b0;
   \       0xEC   0xE586'9000        STR      R9,[R6, #+0]
    208          }
   \       0xF0   0xE8BD'4FF1        POP      {R0,R4-R11,LR}
   \       0xF4   0xE12F'FF1E        BX       LR               ;; return
    209          
    210          /*******************************************************************************
    211          * Function Name  : WDG_PeriodValueConfig
    212          * Description    : Sets the prescaler and counter reload value.
    213          * Input          : Time: the amount of needed time, in microseconds.
    214          * Output         : None.
    215          * Return         : None.
    216          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    217          void WDG_PeriodValueConfig ( u32 Time )
    218          {
   \                     WDG_PeriodValueConfig:
   \        0x0   0xE92D'401C        PUSH     {R2-R4,LR}
   \        0x4   0xE1B0'4000        MOVS     R4,R0
    219            u16 a;
    220            u32 n, b;
    221          
    222            n = Time * (RCCU_FrequencyValue(RCCU_PCLK2) / 1000000);
   \        0x8   0xE3A0'0003        MOV      R0,#+3
   \        0xC   0x....'....        BL       RCCU_FrequencyValue
   \       0x10   0xE3A0'1AF4        MOV      R1,#+999424
   \       0x14   0xE381'1F90        ORR      R1,R1,#0x240
   \       0x18   0x....'....        BL       __aeabi_uidiv
   \       0x1C   0xE1B0'1000        MOVS     R1,R0
   \       0x20   0xE010'0491        MULS     R0,R1,R4
    223            FindFactors(n, &a, &b);
   \       0x24   0xE28D'2004        ADD      R2,SP,#+4
   \       0x28   0xE1B0'100D        MOVS     R1,SP
   \       0x2C   0x....'....        BL       FindFactors
    224            WDG->PR = a - 1;
   \       0x30   0xE3A0'00FF        MOV      R0,#+255
   \       0x34   0xE380'0CFF        ORR      R0,R0,#0xFF00
   \       0x38   0xE1DD'10B0        LDRH     R1,[SP, #+0]
   \       0x3C   0xE090'1001        ADDS     R1,R0,R1
   \       0x40   0xE3A0'224E        MOV      R2,#-536870908
   \       0x44   0xE382'2CE0        ORR      R2,R2,#0xE000
