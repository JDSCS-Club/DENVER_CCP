     41          * Input          : None.
     42          * Output         : None.
     43          * Return         : None.
     44          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     45          void WDG_CntRefresh (void)
     46          {
     47            /* Write the first value in the key register */
     48            WDG->KR = 0xA55A;
   \                     WDG_CntRefresh:
   \        0x0   0x....'....        LDR      R0,??DataTable4  ;; 0xe000e018
   \        0x4   0xE3A0'105A        MOV      R1,#+90
   \        0x8   0xE381'1CA5        ORR      R1,R1,#0xA500
   \        0xC   0xE1C0'10B0        STRH     R1,[R0, #+0]
     49          
     50            /* Write the second value in the key register */
     51            WDG->KR = 0x5AA5;
   \       0x10   0xE3A0'10A5        MOV      R1,#+165
   \       0x14   0xE381'1C5A        ORR      R1,R1,#0x5A00
   \       0x18   0xE1C0'10B0        STRH     R1,[R0, #+0]
     52          }
   \       0x1C   0xE12F'FF1E        BX       LR               ;; return
