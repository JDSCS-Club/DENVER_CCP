    160            }	
    161            else
    162            {
    163              return (-x);	
   \                     ??abs_value_1:
   \        0x8   0xE270'0000        RSBS     R0,R0,#+0
   \                     ??abs_value_0:
   \        0xC   0xE12F'FF1E        BX       LR               ;; return
    164            }
    165          }
