   \        0x4   0xE350'0001        CMP      R0,#+1
   \        0x8   0x1A00'0005        BNE      ??WDG_CntOnOffConfig_0
     93            {
     94              WDG->CR |= 0x0002;
   \        0xC   0xE3A0'04E0        MOV      R0,#-536870912
   \       0x10   0xE380'0CE0        ORR      R0,R0,#0xE000
   \       0x14   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x18   0xE391'1002        ORRS     R1,R1,#0x2
   \       0x1C   0xE1C0'10B0        STRH     R1,[R0, #+0]
   \       0x20   0xEA00'0006        B        ??WDG_CntOnOffConfig_1
     95            }
     96            else
     97            {
     98              WDG->CR &= ~0x0002;
   \                     ??WDG_CntOnOffConfig_0:
   \       0x24   0xE3A0'04E0        MOV      R0,#-536870912
   \       0x28   0xE380'0CE0        ORR      R0,R0,#0xE000
   \       0x2C   0xE1D0'10B0        LDRH     R1,[R0, #+0]
   \       0x30   0xE3A0'20FD        MOV      R2,#+253
   \       0x34   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x38   0xE012'1001        ANDS     R1,R2,R1
   \       0x3C   0xE1C0'10B0        STRH     R1,[R0, #+0]
     99            }
    100          }
   \                     ??WDG_CntOnOffConfig_1:
   \       0x40   0xE12F'FF1E        BX       LR               ;; return
    101          
