     27          /*******************************************************************************
     28          * Function Name  : RCCU_Div2Config
     29          * Description    : This routine is used to enable or disable the programmable
     30          *                  clock division of the CLOCK1 input clock signal by 2. It 
     31          *                  sets or clears the Div2 flag in the CLK_FLAG register.
     32          * Input          : - NewState: specifies whether the programmable divider can 
     33          *                     divide the CLOCK1 input clock signal by two or not.
     34          *                     it can be: 
     35          *                     ENABLE to enable the division by two of CLK signal. 
     36          *                     DISABLE to disable the division by two of CLK signal.
     37          * Output         : None.
     38          * Return         : None.
     39          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     40          void RCCU_Div2Config (FunctionalState NewState)
     41          {
     42            /* CLK is divided by 2 */	
     43            if (NewState == ENABLE)
   \                     RCCU_Div2Config:
   \        0x0   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \        0x4   0xE350'0001        CMP      R0,#+1
   \        0x8   0x1A00'0004        BNE      ??RCCU_Div2Config_0
     44            {
     45              RCCU->CFR |= RCCU_Div2_Mask;
   \        0xC   0xE3A0'028A        MOV      R0,#-1610612728
   \       0x10   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x14   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x18   0xE580'1000        STR      R1,[R0, #+0]
   \       0x1C   0xEA00'0003        B        ??RCCU_Div2Config_1
     46            }  
     47            /* No division of CLK frequency */
     48            else
     49            {
     50              RCCU->CFR &= ~RCCU_Div2_Mask;
   \                     ??RCCU_Div2Config_0:
   \       0x20   0xE3A0'028A        MOV      R0,#-1610612728
   \       0x24   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x28   0xE3D1'1C80        BICS     R1,R1,#0x8000
   \       0x2C   0xE580'1000        STR      R1,[R0, #+0]
     51            }
     52          }
   \                     ??RCCU_Div2Config_1:
   \       0x30   0xE12F'FF1E        BX       LR               ;; return
     53          
     54          /*******************************************************************************
     55          * Function Name  : RCCU_Div2Status
     56          * Description    : This routine is used to get the current status of the
     57          *                  programmable clock division by two. It checks the status 
     58          *                  of the Div2 flag in the CLK_FLAG register.
     59          * Input          : None.
     60          * Output         : None.
     61          * Return         : The Div2 Flag status.
     62          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     63          FlagStatus RCCU_Div2Status (void)
     64          {
     65            if ((RCCU->CFR & RCCU_Div2_Mask) == 0)
   \                     RCCU_Div2Status:
   \        0x0   0xE3A0'028A        MOV      R0,#-1610612728
   \        0x4   0xE590'0000        LDR      R0,[R0, #+0]
   \        0x8   0xE310'0C80        TST      R0,#0x8000
   \        0xC   0x1A00'0001        BNE      ??RCCU_Div2Status_0
     66            {
     67              return RESET;
   \       0x10   0xE3A0'0000        MOV      R0,#+0
   \       0x14   0xEA00'0000        B        ??RCCU_Div2Status_1
     68            }
     69            else
     70            {
     71              return SET;	
   \                     ??RCCU_Div2Status_0:
   \       0x18   0xE3A0'0001        MOV      R0,#+1
   \                     ??RCCU_Div2Status_1:
   \       0x1C   0xE12F'FF1E        BX       LR               ;; return
     72            }
     73          }
