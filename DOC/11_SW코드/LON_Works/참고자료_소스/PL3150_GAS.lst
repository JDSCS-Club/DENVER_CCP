(0276) // TX 1 BYTE PROGRAM
(0277) void RS232_Send_Byte(BYTE DATA)
(0278)  { 	
(0279) // PORTB = 0x00;
(0280)  while(!(UCSRA & 0x20));
_RS232_Send_Byte:
  DATA                 --> R16
    019B 9B5D      SBIS	P0B,5
    019C CFFE      RJMP	_RS232_Send_Byte
(0281)  UDR = DATA;
    019D B90C      OUT	P0C,R16
(0282)  UCSRA |= 0x20; 
    019E 9A5D      SBI	P0B,5
(0283)  //PORTB = 0xFF;
(0284)  }
    019F 9508      RET
_RS232_Send_Bytes:
  C                    --> R20
  Num                  --> R22
    01A0 D09D      RCALL	push_gset2
    01A1 2F60      MOV	R22,R16
(0285)      
(0286) 
(0287) // TX BYTES PGM
(0288) void RS232_Send_Bytes(BYTE Num)
(0289) {
(0290) BYTE C;
(0291) //LED422_ON;
(0292) for(C=0; C<Num; C++) RS232_Send_Byte(ADC_DATA[C]);  
    01A2 2744      CLR	R20
    01A3 C009      RJMP	0x01AD
    01A4 E68A      LDI	R24,0x6A
    01A5 E090      LDI	R25,0
    01A6 2FE4      MOV	R30,R20
    01A7 27FF      CLR	R31
    01A8 0FE8      ADD	R30,R24
    01A9 1FF9      ADC	R31,R25
    01AA 8100      LDD	R16,0+Z
    01AB DFEF      RCALL	_RS232_Send_Byte
    01AC 9543      INC	R20
    01AD 1746      CP	R20,R22
    01AE F3A8      BCS	0x01A4
(0293) //LED422_OFF;
(0294) }
    01AF D075      RCALL	pop_gset2
    01B0 9508      RET
