    01DE F0B1      BEQ	0x01F5
    01DF 3043      CPI	R20,3
    01E0 E0E0      LDI	R30,0
    01E1 075E      CPC	R21,R30
    01E2 F119      BEQ	0x0206
    01E3 C035      RJMP	0x0219
(0325) 	   {
(0326) 	   case 1 : ADC_CONVER(GAS);
