(0251) //call this routine to initialise all peripherals
(0252) void init_devices(void)
(0253) {
(0254)  //stop errant interrupts until set up
(0255)  CLI(); //disable all interrupts
_init_devices:
    0182 94F8      BCLR	7
(0256)  port_init();
    0183 DEAF      RCALL	_port_init
(0257)  timer1_init();
    0184 DEBB      RCALL	_timer1_init
(0258)  uart0_init();
    0185 DED0      RCALL	_uart0_init
(0259)  adc_init();
    0186 DEDB      RCALL	_adc_init
(0260) 
(0261)  MCUCR = 0x00;
    0187 2422      CLR	R2
    0188 BE25      OUT	P35,R2
(0262)  GICR  = 0x00;
    0189 BE2B      OUT	P3B,R2
(0263)  TIMSK = 0x05; //timer interrupt sources
    018A E085      LDI	R24,5
    018B BF89      OUT	P39,R24
(0264)  
(0265)  flag = 0; 
    018C 92200072  STS	_flag,R2
(0266)  GAS_SEN_EN;
    018E 9AA9      SBI	P15,1
(0267)  T_COUNT = 0;
    018F 92200067  STS	_T_COUNT,R2
(0268)  NO_COUNT = 0;
    0191 92200061  STS	_NO_COUNT,R2
(0269)  ADC_DATA[0] = 0x02;
    0193 E082      LDI	R24,2
    0194 9380006A  STS	_ADC_DATA,R24
(0270)  ADC_DATA[5] = 0x03;
    0196 E083      LDI	R24,3
    0197 9380006F  STS	0x6F,R24
(0271)  
(0272)  SEI(); //re-enable interrupts
    0199 9478      BSET	7
(0273)  //all peripherals are now initialised
(0274) }
    019A 9508      RET
