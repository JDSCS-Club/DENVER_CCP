    028D 0000      NOP
    028E 0000      NOP
    028F 0000      NOP
(0153) 	}while(0);//while((BUSY)); 	  
(0154) 	BUSY_OUT;asm("NOP");asm("NOP");asm("NOP");
    0290 9AD7      SBI	P1A,7
    0291 0000      NOP
    0292 0000      NOP
    0293 0000      NOP
(0155) 	LCD_CS1_OFF; LCD_CS2_OFF;
    0294 91800062  LDS	R24,0x62
    0296 7F8E      ANDI	R24,0xFE
    0297 93800062  STS	0x62,R24
    0299 91800062  LDS	R24,0x62
    029B 7F8D      ANDI	R24,0xFD
    029C 93800062  STS	0x62,R24
(0156) }
    029E 9508      RET
