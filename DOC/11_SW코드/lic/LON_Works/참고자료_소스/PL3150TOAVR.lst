(0051) 
(0052) #pragma interrupt_handler Uart0_rx_Interrupt:19
(0053) void Uart0_rx_Interrupt(void)
(0054) {
(0055)  //uart has received a character in UDR
(0056) UART0_RX_DATA[UART0_RX_Count] = UDR0;
    04F4 E081      LDI	R24,1
    04F5 E093      LDI	R25,3
    04F6 91E002CE  LDS	R30,_UART0_RX_Count
    04F8 27FF      CLR	R31
    04F9 0FE8      ADD	R30,R24
    04FA 1FF9      ADC	R31,R25
    04FB B02C      IN	R2,P0C
    04FC 8220      STD	R2,0+Z
(0057)    if(UART0_RX_DATA[0] == STX)
    04FD 91800301  LDS	R24,_UART0_RX_DATA
    04FF 3082      CPI	R24,2
    0500 F4F1      BNE	0x051F
(0058)    {
(0059) 	UART0_RX_Count++;
    0501 918002CE  LDS	R24,_UART0_RX_Count
    0503 5F8F      SUBI	R24,0xFF
    0504 938002CE  STS	_UART0_RX_Count,R24
(0060) 	switch(UART0_RX_Count)
    0506 2F08      MOV	R16,R24
    0507 2711      CLR	R17
    0508 3001      CPI	R16,1
    0509 E0E0      LDI	R30,0
    050A 071E      CPC	R17,R30
    050B F049      BEQ	0x0515
    050C 3001      CPI	R16,1
    050D E0E0      LDI	R30,0
    050E 071E      CPC	R17,R30
    050F F094      BLT	0x0522
    0510 3005      CPI	R16,5
    0511 E0E0      LDI	R30,0
    0512 071E      CPC	R17,R30
    0513 F019      BEQ	0x0517
    0514 C00D      RJMP	0x0522
(0061) 	{
(0062) 		case 1: LED_50TOAVR_ON;//LED232_ON; 
    0515 98AC      CBI	P15,4
(0063) 			break;
    0516 C00B      RJMP	0x0522
(0064) 		case 5: LED_50TOAVR_OFF;UART0_RX_Flag = ON; UART0_RX_Count = 0;
    0517 9AAC      SBI	P15,4
    0518 E081      LDI	R24,1
    0519 938002CC  STS	_UART0_RX_Flag,R24
    051B 2422      CLR	R2
    051C 922002CE  STS	_UART0_RX_Count,R2
(0065) 			break;
(0066) 	}
(0067)    }
    051E C003      RJMP	0x0522
(0068)    else UART0_RX_Count = 0;
    051F 2422      CLR	R2
    0520 922002CE  STS	_UART0_RX_Count,R2
(0069) 	
(0070) }
    0522 9029      LD	R2,Y+
    0523 BE2F      OUT	P3F,R2
    0524 91F9      LD	R31,Y+
    0525 91E9      LD	R30,Y+
    0526 9199      LD	R25,Y+
    0527 9189      LD	R24,Y+
    0528 9119      LD	R17,Y+
    0529 9109      LD	R16,Y+
    052A 9029      LD	R2,Y+
    052B 9518      RETI
_adc_isr:
    052C 922A      ST	R2,-Y
    052D 923A      ST	R3,-Y
    052E 938A      ST	R24,-Y
    052F B62F      IN	R2,P3F
    0530 922A      ST	R2,-Y
(0071) 
