(0073) #pragma interrupt_handler adc_isr:22
(0074) void adc_isr(void)
(0075) {
(0076)  //conversion complete, read value (int) using...
(0077)   ADC_DATAS = ADC;
    0531 B024      IN	R2,P04
    0532 B035      IN	R3,P05
    0533 923002BE  STS	_ADC_DATAS+1,R3
    0535 922002BD  STS	_ADC_DATAS,R2
(0078)   adc_flagg = ON;
    0537 E081      LDI	R24,1
    0538 938002BC  STS	_adc_flagg,R24
(0079) } 
    053A 9029      LD	R2,Y+
    053B BE2F      OUT	P3F,R2
    053C 9189      LD	R24,Y+
    053D 9039      LD	R3,Y+
    053E 9029      LD	R2,Y+
    053F 9518      RETI
_timer1_ovf_isr:
    0540 922A      ST	R2,-Y
    0541 938A      ST	R24,-Y
    0542 B62F      IN	R2,P3F
    0543 922A      ST	R2,-Y
(0080) 
