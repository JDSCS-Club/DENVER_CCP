(0101) #pragma interrupt_handler Uart1_rx_Interrupt:31
(0102) void Uart1_rx_Interrupt(void)
(0103) {
(0104)  //uart has received a character in UDR
(0105)  UART1_RX_DATA[UART1_RX_Count] = UDR1;
    0567 EC8F      LDI	R24,0xCF
    0568 E092      LDI	R25,2
    0569 91E002CD  LDS	R30,_UART1_RX_Count
    056B 27FF      CLR	R31
    056C 0FE8      ADD	R30,R24
    056D 1FF9      ADC	R31,R25
    056E 9020009C  LDS	R2,0x9C
    0570 8220      STD	R2,0+Z
(0106)  
(0107)  if (UART1_RX_DATA[0] == STX)
    0571 918002CF  LDS	R24,_UART1_RX_DATA
    0573 3082      CPI	R24,2
    0574 F531      BNE	0x059B
(0108)  {
(0109)  	UART1_RX_Count++;
    0575 918002CD  LDS	R24,_UART1_RX_Count
    0577 5F8F      SUBI	R24,0xFF
    0578 938002CD  STS	_UART1_RX_Count,R24
(0110)  	switch(UART1_RX_Count)
    057A 2F08      MOV	R16,R24
    057B 2711      CLR	R17
    057C 3001      CPI	R16,1
    057D E0E0      LDI	R30,0
    057E 071E      CPC	R17,R30
    057F F069      BEQ	0x058D
    0580 3001      CPI	R16,1
    0581 E0E0      LDI	R30,0
    0582 071E      CPC	R17,R30
    0583 F0D4      BLT	0x059E
    0584 3008      CPI	R16,0x8
    0585 E0E0      LDI	R30,0
    0586 071E      CPC	R17,R30
    0587 F039      BEQ	0x058F
    0588 300A      CPI	R16,0xA
    0589 E0E0      LDI	R30,0
    058A 071E      CPC	R17,R30
    058B F039      BEQ	0x0593
    058C C011      RJMP	0x059E
(0111)  	{
(0112)  		case 1: LED_Zig_ON;
    058D 98A8      CBI	P15,0
(0113)  			    break;
    058E C00F      RJMP	0x059E
(0114) 		case 8: UART_RX_FL = ON;//if(UART1_RX_DATA[3] == 0xF0)
    058F E081      LDI	R24,1
    0590 938002CA  STS	_UART_RX_FL,R24
(0115) 		            // UART1_RX_Count = 0;	
(0116) 			    break;	
    0592 C00B      RJMP	0x059E
(0117)  		case 10:LED_Zig_OFF; UART1_RX_Flag = ON; UART1_RX_Count = 0;
    0593 9AA8      SBI	P15,0
    0594 E081      LDI	R24,1
    0595 938002CB  STS	_UART1_RX_Flag,R24
    0597 2422      CLR	R2
    0598 922002CD  STS	_UART1_RX_Count,R2
(0118)  			    break;
(0119)  	}
(0120)  }
    059A C003      RJMP	0x059E
(0121)  else UART1_RX_Count = 0; 
    059B 2422      CLR	R2
    059C 922002CD  STS	_UART1_RX_Count,R2
(0122) }
    059E 9029      LD	R2,Y+
    059F BE2F      OUT	P3F,R2
    05A0 91F9      LD	R31,Y+
    05A1 91E9      LD	R30,Y+
    05A2 9199      LD	R25,Y+
    05A3 9189      LD	R24,Y+
    05A4 9119      LD	R17,Y+
    05A5 9109      LD	R16,Y+
    05A6 9029      LD	R2,Y+
    05A7 9518      RETI
(0123) 
(0124) void Uart0_TX_byte(unsigned char c)
(0125) {
(0126)  UDR0 = c;
_Uart0_TX_byte:
  c                    --> R16
    05A8 B90C      OUT	P0C,R16
(0127)  while(!(UCSR0A & (1<<UDRE0)));
    05A9 9B5D      SBIS	P0B,5
    05AA CFFE      RJMP	0x05A9
(0128)  UCSR0A |= (1<<UDRE0);
    05AB 9A5D      SBI	P0B,5
(0129) }
    05AC 9508      RET
_Uart0_TX_bytes:
  C                    --> R20
  Num                  --> R22
    05AD 940E090B  CALL	push_gset2
    05AF 2F60      MOV	R22,R16
(0130) 
(0131) void Uart0_TX_bytes(unsigned char Num)
(0132)  {
(0133)  BYTE C;
(0134)  LED_3150_ON;
    05B0 98A9      CBI	P15,1
(0135)  for(C=0; C<Num; C++) Uart0_TX_byte(UART0_TX_DATA[C]);
    05B1 2744      CLR	R20
    05B2 C009      RJMP	0x05BC
    05B3 E685      LDI	R24,0x65
    05B4 E093      LDI	R25,3
    05B5 2FE4      MOV	R30,R20
    05B6 27FF      CLR	R31
    05B7 0FE8      ADD	R30,R24
    05B8 1FF9      ADC	R31,R25
    05B9 8100      LDD	R16,0+Z
    05BA DFED      RCALL	_Uart0_TX_byte
    05BB 9543      INC	R20
    05BC 1746      CP	R20,R22
    05BD F3A8      BCS	0x05B3
(0136)  LED_3150_OFF; 
    05BE 9AA9      SBI	P15,1
(0137)  }
    05BF 940E08EB  CALL	pop_gset2
    05C1 9508      RET
(0138) 
(0139) void Uart1_TX_byte(unsigned char c)
(0140)  {
(0141)  UDR1 = c;
_Uart1_TX_byte:
  c                    --> R16
    05C2 9300009C  STS	0x9C,R16
(0142)  while(!(UCSR1A & (1<<UDRE1)));
    05C4 9020009B  LDS	R2,0x9B
    05C6 FE25      SBRS	R2,5
    05C7 CFFC      RJMP	0x05C4
(0143)  UCSR1A |= (1<<UDRE1);
    05C8 9180009B  LDS	R24,0x9B
    05CA 6280      ORI	R24,0x20
    05CB 9380009B  STS	0x9B,R24
(0144)  }
    05CD 9508      RET
_Uart1_TX_bytes:
  C                    --> R20
  Num                  --> R22
    05CE 940E090B  CALL	push_gset2
    05D0 2F60      MOV	R22,R16
(0145) 
(0146) void Uart1_TX_bytes(unsigned char Num)
(0147)  {
(0148)  BYTE C;
(0149)  //LED422_ON;
(0150)  for(C=0; C<Num; C++) Uart1_TX_bytes(UART1_TX_DATA[C]);
    05D1 2744      CLR	R20
    05D2 C009      RJMP	0x05DC
    05D3 E383      LDI	R24,0x33
    05D4 E093      LDI	R25,3
    05D5 2FE4      MOV	R30,R20
    05D6 27FF      CLR	R31
    05D7 0FE8      ADD	R30,R24
    05D8 1FF9      ADC	R31,R25
    05D9 8100      LDD	R16,0+Z
    05DA DFF3      RCALL	_Uart1_TX_bytes
    05DB 9543      INC	R20
    05DC 1746      CP	R20,R22
    05DD F3A8      BCS	0x05D3
(0151)  //LED422_OFF;
(0152)  }
    05DE 940E08EB  CALL	pop_gset2
    05E0 9508      RET
(0153) 
(0154) 
(0155) void adc_init(void)
(0156) {
(0157)  ADCSRA = 0x00; //disable adc
_adc_init:
    05E1 2422      CLR	R2
    05E2 B826      OUT	P06,R2
(0158)  ADMUX = 0x00; //select adc input 0 
    05E3 B827      OUT	P07,R2
(0159)  ADCSRA = 0x00;
    05E4 B826      OUT	P06,R2
(0160) }
    05E5 9508      RET
(0161)  
(0162) ADC_PROCESS(void)
(0163) {
(0164)     WORD TEMP_DATA = 0x0000;
_ADC_PROCESS:
  IRD                  --> R16
  TEMP_DATA            --> R18
    05E6 2722      CLR	R18
    05E7 2733      CLR	R19
(0165) 	BYTE IRD;
(0166) 	//LED_3150_ON;
(0167)     ADCSRA = 0x9E;     
    05E8 E98E      LDI	R24,0x9E
    05E9 B986      OUT	P06,R24
(0168)     ADMUX = 0x42;
    05EA E482      LDI	R24,0x42
    05EB B987      OUT	P07,R24
(0169)     SEI();     
    05EC 9478      BSET	7
(0170)     adc_flagg = OFF;
    05ED 2422      CLR	R2
    05EE 922002BC  STS	_adc_flagg,R2
(0171)     ADCSRA|=0x40;     
    05F0 9A36      SBI	P06,6
(0172)     while(!(adc_flagg));
    05F1 902002BC  LDS	R2,_adc_flagg
    05F3 2022      TST	R2
    05F4 F3E1      BEQ	0x05F1
(0173)     ADCSRA&=0xBF;  
    05F5 B186      IN	R24,P06
    05F6 7B8F      ANDI	R24,0xBF
    05F7 B986      OUT	P06,R24
(0174)     CLI();
    05F8 94F8      BCLR	7
(0175) 	TEMP_DATA = ADC_DATAS & 0x03FF;
    05F9 912002BD  LDS	R18,_ADC_DATAS
    05FB 913002BE  LDS	R19,_ADC_DATAS+1
    05FD 7033      ANDI	R19,3
(0176)     IRD = TEMP_DATA >> 2; 
    05FE 0189      MOVW	R16,R18
    05FF 9516      LSR	R17
    0600 9507      ROR	R16
    0601 9516      LSR	R17
    0602 9507      ROR	R16
(0177) 	ADCSRA = 0x00;	
    0603 2422      CLR	R2
    0604 B826      OUT	P06,R2
(0178) 	//LED_IRSEN_ON;
(0179) 	SEI();
    0605 9478      BSET	7
(0180) 	return IRD;
    0606 2711      CLR	R17
    0607 9508      RET
(0181)     
(0182) }
(0183) 
(0184) void KEY_Scan(void)
(0185) {
(0186)  	int delay;
(0187) 	
(0188) 	
(0189) 	if(!(KEY1))
_KEY_Scan:
  delay                --> R16
    0608 99B4      SBIC	P16,4
    0609 C013      RJMP	0x061D
(0190) 	{ 
(0191) 	    
(0192) 		for( delay = 0; delay <10000; delay++) asm("NOP");
    060A 2700      CLR	R16
    060B 2711      CLR	R17
    060C 0000      NOP
    060D 5F0F      SUBI	R16,0xFF
    060E 4F1F      SBCI	R17,0xFF
    060F 3100      CPI	R16,0x10
    0610 E2E7      LDI	R30,0x27
    0611 071E      CPC	R17,R30
    0612 F3CC      BLT	0x060C
(0193) 		if(!(KEY1)) KEY_Flag = 1;
    0613 99B4      SBIC	P16,4
    0614 C005      RJMP	0x061A
    0615 E081      LDI	R24,1
    0616 938002C9  STS	_KEY_Flag,R24
    0618 C001      RJMP	0x061A
(0194) 		while(!(KEY1)) asm("NOP");
    0619 0000      NOP
    061A 9BB4      SBIS	P16,4
    061B CFFD      RJMP	0x0619
(0195) 		
(0196) 	}
    061C C018      RJMP	0x0635
(0197) 	else if(!(KEY2))
    061D 99B5      SBIC	P16,5
    061E C013      RJMP	0x0632
(0198) 	{
(0199) 	   
(0200) 		for(delay=0; delay<10000; delay++) asm("NOP");
    061F 2700      CLR	R16
    0620 2711      CLR	R17
    0621 0000      NOP
    0622 5F0F      SUBI	R16,0xFF
    0623 4F1F      SBCI	R17,0xFF
    0624 3100      CPI	R16,0x10
    0625 E2E7      LDI	R30,0x27
    0626 071E      CPC	R17,R30
    0627 F3CC      BLT	0x0621
(0201) 		if(!(KEY2)) KEY_Flag = 2;
    0628 99B5      SBIC	P16,5
    0629 C005      RJMP	0x062F
    062A E082      LDI	R24,2
    062B 938002C9  STS	_KEY_Flag,R24
    062D C001      RJMP	0x062F
(0202) 		while(!(KEY2)) asm("NOP");
    062E 0000      NOP
    062F 9BB5      SBIS	P16,5
