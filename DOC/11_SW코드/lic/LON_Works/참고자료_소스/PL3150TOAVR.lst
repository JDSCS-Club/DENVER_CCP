(0139) void busy(void)
(0140) {
(0141) 	PORTA = 0x80;
_busy:
    025C E880      LDI	R24,0x80
    025D BB8B      OUT	P1B,R24
(0142) 	BUSY_IN; asm("NOP");asm("NOP");asm("NOP");
    025E 98D7      CBI	P1A,7
    025F 0000      NOP
    0260 0000      NOP
    0261 0000      NOP
(0143) 	LCD_CS1_ON; asm("NOP");asm("NOP");asm("NOP");
    0262 91800062  LDS	R24,0x62
    0264 6081      ORI	R24,1
    0265 93800062  STS	0x62,R24
    0267 0000      NOP
    0268 0000      NOP
    0269 0000      NOP
(0144) 	LCD_CS2_ON; asm("NOP");asm("NOP");asm("NOP");
    026A 91800062  LDS	R24,0x62
    026C 6082      ORI	R24,2
    026D 93800062  STS	0x62,R24
    026F 0000      NOP
    0270 0000      NOP
    0271 0000      NOP
(0145) 	LCD_READ; asm("NOP");asm("NOP");asm("NOP");
    0272 9AC2      SBI	P18,2
    0273 0000      NOP
    0274 0000      NOP
    0275 0000      NOP
(0146) 	LCD_CMD; asm("NOP"); asm("NOP");asm("NOP");
    0276 98C1      CBI	P18,1
    0277 0000      NOP
    0278 0000      NOP
    0279 0000      NOP
(0147) 	do
(0148) 	{
(0149) 	 LCD_ENABLE; asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    027A 9AC3      SBI	P18,3
    027B 0000      NOP
    027C 0000      NOP
    027D 0000      NOP
    027E 0000      NOP
    027F 0000      NOP
(0150) 	 LCD_DISENABLE;asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    0280 98C3      CBI	P18,3
    0281 0000      NOP
    0282 0000      NOP
    0283 0000      NOP
    0284 0000      NOP
    0285 0000      NOP
(0151) 	 asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    0286 0000      NOP
    0287 0000      NOP
    0288 0000      NOP
    0289 0000      NOP
    028A 0000      NOP
(0152) 	 asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    028B 0000      NOP
