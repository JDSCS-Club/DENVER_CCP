  chip                 --> Y+4
  RW                   --> R20
  DI                   --> R22
    029F 940E090B  CALL	push_gset2
    02A1 01A9      MOVW	R20,R18
    02A2 01B8      MOVW	R22,R16
(0157) 
(0158) void control(int DI, int RW, int chip)    /* Á¦ľî ˝ĹČŁ ľ˛±â */
(0159) {
(0160) 	busy();
    02A3 DFB8      RCALL	_busy
(0161) 	if(DI){ PORTB = PORTB | BIT1; asm("NOP");asm("NOP");asm("NOP");	}
    02A4 3060      CPI	R22,0
    02A5 0767      CPC	R22,R23
    02A6 F029      BEQ	0x02AC
    02A7 9AC1      SBI	P18,1
    02A8 0000      NOP
    02A9 0000      NOP
    02AA 0000      NOP
    02AB C004      RJMP	0x02B0
(0162) 	else { PORTB = PORTB & ~BIT1; asm("NOP");asm("NOP");asm("NOP"); }
    02AC 98C1      CBI	P18,1
    02AD 0000      NOP
    02AE 0000      NOP
    02AF 0000      NOP
(0163) 	if(RW) { PORTB = PORTB | BIT2; asm("NOP");asm("NOP");asm("NOP"); }
    02B0 3040      CPI	R20,0
    02B1 0745      CPC	R20,R21
    02B2 F029      BEQ	0x02B8
    02B3 9AC2      SBI	P18,2
    02B4 0000      NOP
    02B5 0000      NOP
    02B6 0000      NOP
    02B7 C004      RJMP	0x02BC
(0164) 	else { PORTB = PORTB & ~BIT2; asm("NOP");asm("NOP");asm("NOP"); }
    02B8 98C2      CBI	P18,2
    02B9 0000      NOP
    02BA 0000      NOP
    02BB 0000      NOP
(0165) 	PORTF = PORTF | chip; asm("NOP");asm("NOP");asm("NOP");	
    02BC 90200062  LDS	R2,0x62
    02BE 2433      CLR	R3
    02BF 800C      LDD	R0,4+Y
    02C0 801D      LDD	R1,5+Y
    02C1 2820      OR	R2,R0
    02C2 2831      OR	R3,R1
    02C3 92200062  STS	0x62,R2
    02C5 0000      NOP
    02C6 0000      NOP
    02C7 0000      NOP
(0166) }
    02C8 940E08EB  CALL	pop_gset2
    02CA 9508      RET
_goline:
  x                    --> R20
    02CB 940E08F4  CALL	push_gset1
    02CD 01A8      MOVW	R20,R16
    02CE 9722      SBIW	R28,2
(0167) 
(0168) void goline(int x)			/* ÁŮ ąŮ˛Ů±â */
(0169) {
(0170) 	busy();
    02CF DF8C      RCALL	_busy
(0171) 	
(0172) 	control(I, W, CS1+CS2);
    02D0 E083      LDI	R24,3
    02D1 E090      LDI	R25,0
    02D2 8388      STD	R24,0+Y
    02D3 8399      STD	R25,1+Y
    02D4 2722      CLR	R18
    02D5 2733      CLR	R19
    02D6 2700      CLR	R16
    02D7 2711      CLR	R17
    02D8 DFC6      RCALL	_control
(0173) 	PORTA = startX+x;asm("NOP");asm("NOP");asm("NOP");
    02D9 01CA      MOVW	R24,R20
    02DA 5488      SUBI	R24,0x48
    02DB 4F9F      SBCI	R25,0xFF
    02DC BB8B      OUT	P1B,R24
    02DD 0000      NOP
    02DE 0000      NOP
    02DF 0000      NOP
(0174) 	LCD_ENABLE; asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP"); 
    02E0 9AC3      SBI	P18,3
    02E1 0000      NOP
    02E2 0000      NOP
    02E3 0000      NOP
    02E4 0000      NOP
    02E5 0000      NOP
(0175) 	LCD_DISENABLE;asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    02E6 98C3      CBI	P18,3
    02E7 0000      NOP
    02E8 0000      NOP
    02E9 0000      NOP
    02EA 0000      NOP
    02EB 0000      NOP
(0176) 	control(I, W, CS1);
    02EC E081      LDI	R24,1
    02ED E090      LDI	R25,0
    02EE 8388      STD	R24,0+Y
    02EF 8399      STD	R25,1+Y
    02F0 2722      CLR	R18
    02F1 2733      CLR	R19
    02F2 2700      CLR	R16
    02F3 2711      CLR	R17
    02F4 DFAA      RCALL	_control
(0177) 	PORTA = startY+4;asm("NOP");asm("NOP");asm("NOP");
    02F5 E484      LDI	R24,0x44
    02F6 BB8B      OUT	P1B,R24
    02F7 0000      NOP
    02F8 0000      NOP
    02F9 0000      NOP
(0178) 	LCD_ENABLE; asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    02FA 9AC3      SBI	P18,3
    02FB 0000      NOP
    02FC 0000      NOP
    02FD 0000      NOP
    02FE 0000      NOP
    02FF 0000      NOP
(0179) 	LCD_DISENABLE;asm("NOP");asm("NOP");asm("NOP");asm("NOP");asm("NOP");
    0300 98C3      CBI	P18,3
    0301 0000      NOP
    0302 0000      NOP
    0303 0000      NOP
    0304 0000      NOP
    0305 0000      NOP
(0180) 	control(I, W, CS2);
    0306 E082      LDI	R24,2
    0307 E090      LDI	R25,0
    0308 8388      STD	R24,0+Y
    0309 8399      STD	R25,1+Y
    030A 2722      CLR	R18
    030B 2733      CLR	R19
