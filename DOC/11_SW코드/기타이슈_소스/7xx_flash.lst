     57          /*******************************************************************************
     58          * Function Name  : FLASH_DeInit
     59          * Description    : Deinitializes the Flash module registers to their default
     60          *                  reset values.
     61          * Input          : None
     62          * Output         : None
     63          * Return         : None
     64          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     65          void FLASH_DeInit(void)
     66          {
     67            /* Reset the Flash control registers */
     68            FLASH->CR0 = 0x00000000;
   \                     FLASH_DeInit:
   \        0x0   0xE3A0'0000        MOV      R0,#+0
   \        0x4   0xE3A0'1440        MOV      R1,#+1073741824
   \        0x8   0xE381'1940        ORR      R1,R1,#0x100000
   \        0xC   0xE581'0000        STR      R0,[R1, #+0]
     69            FLASH->CR1 = 0x00000000;
   \       0x10   0xE3A0'1244        MOV      R1,#+1073741828
   \       0x14   0xE381'1940        ORR      R1,R1,#0x100000
   \       0x18   0xE581'0000        STR      R0,[R1, #+0]
     70          
     71            /* Reset the Flash data registers */
     72            FLASH->DR0 = 0xFFFFFFFF;
   \       0x1C   0xE3E0'1000        MVN      R1,#+0
   \       0x20   0xE3A0'2284        MOV      R2,#+1073741832
   \       0x24   0xE382'2940        ORR      R2,R2,#0x100000
   \       0x28   0xE582'1000        STR      R1,[R2, #+0]
     73            FLASH->DR1 = 0xFFFFFFFF;
   \       0x2C   0xE3A0'22C4        MOV      R2,#+1073741836
   \       0x30   0xE382'2940        ORR      R2,R2,#0x100000
   \       0x34   0xE582'1000        STR      R1,[R2, #+0]
     74          
     75            /* Reset the Flash address register */
     76            FLASH->AR = 0x00000000;
   \       0x38   0xE3A0'1141        MOV      R1,#+1073741840
   \       0x3C   0xE381'1940        ORR      R1,R1,#0x100000
   \       0x40   0xE581'0000        STR      R0,[R1, #+0]
     77          
     78            /* Reset the Flash error register */
     79            FLASH->ER  = 0x00000000;
   \       0x44   0xE3A0'1151        MOV      R1,#+1073741844
   \       0x48   0xE381'1940        ORR      R1,R1,#0x100000
   \       0x4C   0xE581'0000        STR      R0,[R1, #+0]
     80          }
   \       0x50   0xE12F'FF1E        BX       LR               ;; return
     81          
     82          /*******************************************************************************
     83          * Function Name  : FLASH_WriteWord
     84          * Description    : Writes a Word to a Flash address destination.
     85          * Input          : - FLASH_Address: the Address of the destination.
     86          *                  - FLASH_Data: the data to be programmed.
     87          * Output         : None
     88          * Return         : None
     89          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     90          void FLASH_WriteWord(u32 FLASH_Address, u32 FLASH_Data)
     91          {
     92            /* Set the word programming bit */
     93            FLASH->CR0 |= FLASH_WPG_MASK;
   \                     FLASH_WriteWord:
   \        0x0   0xE3A0'2440        MOV      R2,#+1073741824
   \        0x4   0xE382'2940        ORR      R2,R2,#0x100000
   \        0x8   0xE592'3000        LDR      R3,[R2, #+0]
   \        0xC   0xE393'3580        ORRS     R3,R3,#0x20000000
   \       0x10   0xE582'3000        STR      R3,[R2, #+0]
     94            /* Load the destination address */
     95            FLASH->AR   = FLASH_Address;
   \       0x14   0xE3A0'3141        MOV      R3,#+1073741840
   \       0x18   0xE383'3940        ORR      R3,R3,#0x100000
   \       0x1C   0xE583'0000        STR      R0,[R3, #+0]
     96            /* Load DATA to be programmed */
     97            FLASH->DR0  = FLASH_Data;
   \       0x20   0xE3A0'0284        MOV      R0,#+1073741832
   \       0x24   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x28   0xE580'1000        STR      R1,[R0, #+0]
     98            /* Start the operation */
     99            FLASH->CR0 |= FLASH_WMS_MASK;
   \       0x2C   0xE592'0000        LDR      R0,[R2, #+0]
   \       0x30   0xE390'0480        ORRS     R0,R0,#0x80000000
   \       0x34   0xE582'0000        STR      R0,[R2, #+0]
    100          }
   \       0x38   0xE12F'FF1E        BX       LR               ;; return
    101          
    102          /*******************************************************************************
    103          * Function Name  : FLASH_WriteDoubleWord
    104          * Description    : Writes Double Word to the Flash.
    105          * Input          : - FLASH_Address: the destination address.
    106          *                  - FLASH_Data_1: the first word to be programmed.
    107          *                  - FLASH_Data_2: the second word to be programmed.
    108          * Output         : None
    109          * Return         : None
    110          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    111          void FLASH_WriteDoubleWord(u32 FLASH_Address, u32 FLASH_Data_1, u32 FLASH_Data_2)
    112          {
    113            /* Set the double word programming bit */
    114            FLASH->CR0 |= FLASH_DWPG_MASK;
   \                     FLASH_WriteDoubleWord:
   \        0x0   0xE3A0'3440        MOV      R3,#+1073741824
   \        0x4   0xE383'3940        ORR      R3,R3,#0x100000
   \        0x8   0xE593'C000        LDR      R12,[R3, #+0]
   \        0xC   0xE39C'C540        ORRS     R12,R12,#0x10000000
   \       0x10   0xE583'C000        STR      R12,[R3, #+0]
    115            /* Load the destination address */
    116            FLASH->AR   = FLASH_Address;
   \       0x14   0xE3A0'C141        MOV      R12,#+1073741840
   \       0x18   0xE38C'C940        ORR      R12,R12,#0x100000
   \       0x1C   0xE58C'0000        STR      R0,[R12, #+0]
    117            /* Load FLASH_Data_1 in the DR0 register */
    118            FLASH->DR0  = FLASH_Data_1;
   \       0x20   0xE3A0'0284        MOV      R0,#+1073741832
   \       0x24   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x28   0xE580'1000        STR      R1,[R0, #+0]
    119            /* Load FLASH_Data_2 in the DR1 register */
    120            FLASH->DR1  = FLASH_Data_2;
   \       0x2C   0xE3A0'02C4        MOV      R0,#+1073741836
   \       0x30   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x34   0xE580'2000        STR      R2,[R0, #+0]
    121            /* Start the operation */
    122            FLASH->CR0 |= FLASH_WMS_MASK;
   \       0x38   0xE593'0000        LDR      R0,[R3, #+0]
   \       0x3C   0xE390'0480        ORRS     R0,R0,#0x80000000
   \       0x40   0xE583'0000        STR      R0,[R3, #+0]
    123          }
   \       0x44   0xE12F'FF1E        BX       LR               ;; return
    124          
    125          /*******************************************************************************
    126          * Function Name  : FLASH_EraseSector
    127          * Description    : Erases one or multiple sectors on a flash bank.
    128          * Input          : FLASH_Sectors: the sectors to be erased.
    129          *                  This parameter can be one of the following values:
    130          *                      - FLASH_BANK0_SECTOR0: Bank 0 sector 0.
    131          *                      - FLASH_BANK0_SECTOR1: Bank 0 sector 1.
    132          *                      - FLASH_BANK0_SECTOR2: Bank 0 sector 2.
    133          *                      - FLASH_BANK0_SECTOR3: Bank 0 sector 3.
    134          *                      - FLASH_BANK0_SECTOR4: Bank 0 sector 4.
    135          *                      - FLASH_BANK0_SECTOR5: Bank 0 sector 5.
    136          *                      - FLASH_BANK0_SECTOR6: Bank 0 sector 6.
    137          *                      - FLASH_BANK0_SECTOR7: Bank 0 sector 7.
    138          *                      - FLASH_BANK0_MODULE:  Bank 0 module.
    139          *                      - FLASH_BANK1_SECTOR0: Bank 1 sector 0. (N.A for STR73x)
    140          *                      - FLASH_BANK1_SECTOR1: Bank 1 sector 1. (N.A for STR73x)
    141          *                      - FLASH_BANK1_MODULE:  Bank 1 module.   (N.A for STR73x)
    142          * Output         : None
    143          * Return         : None
    144          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    145          void FLASH_EraseSector(u32 FLASH_Sectors)
    146          {
    147            /* Set the sector erase bit */
    148            FLASH->CR0 |= FLASH_SER_MASK;
   \                     FLASH_EraseSector:
   \        0x0   0xE3A0'1440        MOV      R1,#+1073741824
   \        0x4   0xE381'1940        ORR      R1,R1,#0x100000
   \        0x8   0xE591'2000        LDR      R2,[R1, #+0]
   \        0xC   0xE392'2680        ORRS     R2,R2,#0x8000000
   \       0x10   0xE581'2000        STR      R2,[R1, #+0]
    149            /* Select the sectors to be erased */
    150            FLASH->CR1 |= FLASH_Sectors;
   \       0x14   0xE3A0'2244        MOV      R2,#+1073741828
   \       0x18   0xE382'2940        ORR      R2,R2,#0x100000
   \       0x1C   0xE592'3000        LDR      R3,[R2, #+0]
   \       0x20   0xE190'0003        ORRS     R0,R0,R3
   \       0x24   0xE582'0000        STR      R0,[R2, #+0]
    151            /* Start the operation */
    152            FLASH->CR0 |= FLASH_WMS_MASK;
   \       0x28   0xE591'0000        LDR      R0,[R1, #+0]
   \       0x2C   0xE390'0480        ORRS     R0,R0,#0x80000000
   \       0x30   0xE581'0000        STR      R0,[R1, #+0]
    153          }
   \       0x34   0xE12F'FF1E        BX       LR               ;; return
    154          
    155          /*******************************************************************************
    156          * Function Name  : FLASH_SuspendOperation
    157          * Description    : Suspends the current operation.
    158          * Input          : None
    159          * Output         : None
    160          * Return         : Flash Control register content.
    161          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    162          u32 FLASH_SuspendOperation(void)
    163          {
   \                     FLASH_SuspendOperation:
   \        0x0   0xE92D'4010        PUSH     {R4,LR}
    164            u32 FLASH_CONTROL_REGISTER = 0x0;
   \        0x4   0xE3A0'0000        MOV      R0,#+0
    165            /* Wait until register's unlock */
    166            while(FLASH->CR0 & 0x10);
   \                     ??FLASH_SuspendOperation_0:
   \        0x8   0xE3A0'0440        MOV      R0,#+1073741824
   \        0xC   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x10   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x14   0xE311'0010        TST      R1,#0x10
   \       0x18   0x1AFF'FFFA        BNE      ??FLASH_SuspendOperation_0
    167            /* Save the control register content */
    168            FLASH_CONTROL_REGISTER = FLASH->CR0;
   \       0x1C   0xE590'4000        LDR      R4,[R0, #+0]
    169            /* Set the suspend Bit */
    170            FLASH->CR0 |= FLASH_SUSP_MASK;
   \       0x20   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x24   0xE391'1440        ORRS     R1,R1,#0x40000000
   \       0x28   0xE580'1000        STR      R1,[R0, #+0]
    171            /* Wait until the flash controller acknowledges the suspend of the current
    172               operation */
    173            FLASH_WaitForLastOperation();
   \       0x2C   0x....'....        BL       FLASH_WaitForLastOperation
    174            /* Return the suspended operation */
    175            return FLASH_CONTROL_REGISTER;
   \       0x30   0xE1B0'0004        MOVS     R0,R4
   \       0x34   0xE8BD'4010        POP      {R4,LR}
   \       0x38   0xE12F'FF1E        BX       LR               ;; return
    176          }
    177          /*******************************************************************************
    178          * Function Name  : FLASH_ResumeOperation
    179          * Description    : Resumes the suspended operation.
    180          * Input          : FLASH_LastOperation: the Flash control register content
    181          *                  returned by the FLASH_SuspendOperation function.
    182          * Output         : None
    183          * Return         : None
    184          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    185          void FLASH_ResumeOperation(u32 FLASH_LastOperation)
    186          {
    187            /* Clear the suspend Bit */
    188            FLASH->CR0 &= ~FLASH_SUSP_MASK;
   \                     FLASH_ResumeOperation:
   \        0x0   0xE3A0'1440        MOV      R1,#+1073741824
   \        0x4   0xE381'1940        ORR      R1,R1,#0x100000
   \        0x8   0xE591'2000        LDR      R2,[R1, #+0]
   \        0xC   0xE3D2'2440        BICS     R2,R2,#0x40000000
   \       0x10   0xE581'2000        STR      R2,[R1, #+0]
    189            /* Resume the last operation */
    190            FLASH->CR0  = FLASH_LastOperation & ~FLASH_WMS_MASK;
   \       0x14   0xE3D0'0480        BICS     R0,R0,#0x80000000
   \       0x18   0xE581'0000        STR      R0,[R1, #+0]
    191            /* Start the operation */
    192            FLASH->CR0 |= FLASH_WMS_MASK;
   \       0x1C   0xE591'0000        LDR      R0,[R1, #+0]
   \       0x20   0xE390'0480        ORRS     R0,R0,#0x80000000
   \       0x24   0xE581'0000        STR      R0,[R1, #+0]
    193          }
   \       0x28   0xE12F'FF1E        BX       LR               ;; return
    194          
    195          /*******************************************************************************
    196          * Function Name  : FLASH_ITConfig
    197          * Description    : Enables or disables the end of write interrupt.
    198          * Input          : FLASH_NewState: the new state of end of write interrupt.
    199          *                  This parameter can be one of the following values:
    200          *                      - ENABLE:  Enable the end of write interrupt.
    201          *                      - DISABLE: Disable the end of write interrupt.
    202          * Output         : None
    203          * Return         : None
    204          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    205          void FLASH_ITConfig(FunctionalState FLASH_NewState)
    206          {
    207            if(FLASH_NewState == ENABLE)
   \                     FLASH_ITConfig:
   \        0x0   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \        0x4   0xE350'0001        CMP      R0,#+1
   \        0x8   0x1A00'0005        BNE      ??FLASH_ITConfig_0
    208            {
    209              /* Enable the end of write interrupt */
    210              FLASH->CR0  |= FLASH_INTM_MASK;
   \        0xC   0xE3A0'0440        MOV      R0,#+1073741824
   \       0x10   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x14   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x18   0xE391'1980        ORRS     R1,R1,#0x200000
   \       0x1C   0xE580'1000        STR      R1,[R0, #+0]
   \       0x20   0xEA00'0004        B        ??FLASH_ITConfig_1
    211            }
    212            else
    213            {
    214              /* Disable the end of write interrupt */
    215              FLASH->CR0  &= ~FLASH_INTM_MASK;
   \                     ??FLASH_ITConfig_0:
   \       0x24   0xE3A0'0440        MOV      R0,#+1073741824
   \       0x28   0xE380'0940        ORR      R0,R0,#0x100000
   \       0x2C   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x30   0xE3D1'1980        BICS     R1,R1,#0x200000
   \       0x34   0xE580'1000        STR      R1,[R0, #+0]
    216            }
    217          }
   \                     ??FLASH_ITConfig_1:
   \       0x38   0xE12F'FF1E        BX       LR               ;; return
    218          
    219          /*******************************************************************************
    220          * Function Name  : FLASH_GetITStatus
    221          * Description    : Checks whether the specified Flash interrupt pending bit
    222          *                  is set or not
    223          * Input          : None
    224          * Output         : None
    225          * Return         : The new state of the interrupt (SET or RESET)
    226          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    227          FlagStatus FLASH_GetITStatus(void)
    228          {
    229            if((FLASH->CR0 & FLASH_INTP_MASK)!= RESET)
   \                     FLASH_GetITStatus:
   \        0x0   0xE3A0'0440        MOV      R0,#+1073741824
   \        0x4   0xE380'0940        ORR      R0,R0,#0x100000
   \        0x8   0xE590'0000        LDR      R0,[R0, #+0]
   \        0xC   0xE310'0940        TST      R0,#0x100000
   \       0x10   0x0A00'0001        BEQ      ??FLASH_GetITStatus_0
    230            {
    231              return SET;
   \       0x14   0xE3A0'0001        MOV      R0,#+1
   \       0x18   0xEA00'0000        B        ??FLASH_GetITStatus_1
    232            }
    233            else
    234            {
    235              return RESET;
   \                     ??FLASH_GetITStatus_0:
   \       0x1C   0xE3A0'0000        MOV      R0,#+0
   \                     ??FLASH_GetITStatus_1:
   \       0x20   0xE12F'FF1E        BX       LR               ;; return
    236            }
    237          }
