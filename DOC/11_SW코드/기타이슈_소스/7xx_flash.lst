     22          /* Private define ------------------------------------------------------------*/
     23          /* Flash operation enable bit mask */
     24          #define FLASH_SPR_MASK     0x01000000
     25          #define FLASH_SER_MASK     0x08000000
     26          #define FLASH_DWPG_MASK    0x10000000
     27          #define FLASH_WPG_MASK     0x20000000
     28          #define FLASH_SUSP_MASK    0x40000000
     29          #define FLASH_WMS_MASK     0x80000000
     30          
     31          /* Flash interrupt mask */
     32          #define FLASH_INTM_MASK    0x00200000
     33          #define FLASH_INTP_MASK    0x00100000
     34          
     35          #ifdef STR73x
     36            /* STR73x Flash lock and busy bits */
     37            #define FLASH_FLAG_LOCKBSY     0x12
     38          #else
     39            /* STR71x/STR75x Flash lock and busy bits */
     40            #define FLASH_FLAG_LOCKBSY     0x16
     41          #endif
     42          
     43          /* Flash protection mask */
     44          #ifdef STR75x
     45            /* STR75x Readout protection */
     46            #define FLASH_PROTECTION_MASK  0x00000001
     47          #else /* STR71x & STR73x */
     48            /* STR71x & STR73x Debug protection */
     49            #define FLASH_PROTECTION_MASK  0x00000002
     50          #endif
