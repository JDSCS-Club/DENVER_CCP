    239          /*******************************************************************************
    240          * Function Name  : FLASH_ClearITPendingBit
    241          * Description    : Clears the end of write interrupt pending flag.
    242          * Input          : None
    243          * Output         : None
    244          * Return         : None
    245          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    246          void FLASH_ClearITPendingBit(void)
    247          {
    248            FLASH->CR0 &= ~FLASH_INTP_MASK;
   \                     FLASH_ClearITPendingBit:
   \        0x0   0xE3A0'0440        MOV      R0,#+1073741824
   \        0x4   0xE380'0940        ORR      R0,R0,#0x100000
   \        0x8   0xE590'1000        LDR      R1,[R0, #+0]
   \        0xC   0xE3D1'1940        BICS     R1,R1,#0x100000
   \       0x10   0xE580'1000        STR      R1,[R0, #+0]
    249          }
   \       0x14   0xE12F'FF1E        BX       LR               ;; return
