     26          /*******************************************************************************
     27          * Function Name  : TIM_Init
     28          * Description    : This routine is used to Initialize the TIM peripheral
     29          *                  registers to their default values.
     30          * Input          : - TIMx: the Timer to be Initialized.
     31          * Output         : None.
     32          * Return         : None.
     33          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     34          void TIM_Init(TIM_TypeDef *TIMx)
     35          {
     36            TIMx->CR1 = 0x0000;
   \                     TIM_Init:
   \        0x0   0xE3A0'1000        MOV      R1,#+0
   \        0x4   0xE1C0'11B4        STRH     R1,[R0, #+20]
     37            TIMx->CR2 = 0x0000;
   \        0x8   0xE1C0'11B8        STRH     R1,[R0, #+24]
     38            TIMx->SR  = 0x0000;
   \        0xC   0xE1C0'11BC        STRH     R1,[R0, #+28]
     39          }
   \       0x10   0xE12F'FF1E        BX       LR               ;; return
     40          
     41          /*******************************************************************************
     42          * Function Name  : TIM_ClockSourceConfig
     43          * Description    : This routine is used to configure the TIM clock source
     44          * Input          : - TIMx: specifies the TIM to be configured.
     45          *                  - Xclock: specifies the TIM source clock. It can be:
     46          *                     TIM_INTERNAL : the TIM is clocked by the APB2 frequency
     47          *                                    divided by the prescaler value.
     48          *                     TIM_EXTERNAL : the TIM is clocked by an external Clock.
     49          * Output         : None.
     50          * Return         : None.
     51          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     52          void TIM_ClockSourceConfig (TIM_TypeDef *TIMx, TIM_Clocks Xclock)
     53          {
     54            if (Xclock == TIM_EXTERNAL)
   \                     TIM_ClockSourceConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0000        CMP      R1,#+0
   \        0x8   0x1A00'0003        BNE      ??TIM_ClockSourceConfig_0
     55            {
     56              TIMx->CR1 |= TIM_ECKEN_Mask;
   \        0xC   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x10   0xE391'1001        ORRS     R1,R1,#0x1
   \       0x14   0xE1C0'11B4        STRH     R1,[R0, #+20]
   \       0x18   0xEA00'0004        B        ??TIM_ClockSourceConfig_1
     57            }
     58            else
     59            {
     60              TIMx->CR1 &= ~TIM_ECKEN_Mask;
   \                     ??TIM_ClockSourceConfig_0:
   \       0x1C   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x20   0xE3A0'20FE        MOV      R2,#+254
   \       0x24   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x28   0xE012'1001        ANDS     R1,R2,R1
   \       0x2C   0xE1C0'11B4        STRH     R1,[R0, #+20]
     61            }
     62          }
   \                     ??TIM_ClockSourceConfig_1:
   \       0x30   0xE12F'FF1E        BX       LR               ;; return
     63          
     64          /*******************************************************************************
     65          * Function Name  : TIM_ClockSourceValue
     66          * Description    : This routine is used to get the TIM clock source
     67          * Input          : - TIMx: specifies the TIM to check its source clock.
     68          * Output         : None.
     69          * Return         : The TIM source clock. It can be:
     70          *                   TIM_INTERNAL: The TIM is clocked by the APB2 frequency
     71          *                                 divided by the prescaler value.
     72          *                   TIM_EXTERNAL: The TIM is clocked by an external Clock.
     73          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     74          TIM_Clocks TIM_ClockSourceValue (TIM_TypeDef *TIMx)
     75          {
     76            if ((TIMx->CR1 & TIM_ECKEN_Mask) == 0)
   \                     TIM_ClockSourceValue:
   \        0x0   0xE1D0'01B4        LDRH     R0,[R0, #+20]
   \        0x4   0xE310'0001        TST      R0,#0x1
   \        0x8   0x1A00'0001        BNE      ??TIM_ClockSourceValue_0
     77            {
     78              return TIM_INTERNAL;	
   \        0xC   0xE3A0'0001        MOV      R0,#+1
   \       0x10   0xEA00'0000        B        ??TIM_ClockSourceValue_1
     79            }
     80            else
     81            {
     82              return TIM_EXTERNAL;
   \                     ??TIM_ClockSourceValue_0:
   \       0x14   0xE3A0'0000        MOV      R0,#+0
   \                     ??TIM_ClockSourceValue_1:
   \       0x18   0xE12F'FF1E        BX       LR               ;; return
     83            }	
     84          }
     85          
     86          /*******************************************************************************
     87          * Function Name  : TIM_PrescalerConfig
     88          * Description    : This routine is used to configure the TIM prescaler value
     89          *                  to divide the internal clock.
     90          * Input          : - TIMx: specifies the TIM to be configured.
     91          *                  - Xprescaler: specifies the TIM prescaler value (8bit).
     92          * Output         : None.
     93          * Return         : None.
     94          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     95          void TIM_PrescalerConfig (TIM_TypeDef *TIMx, u8 Xprescaler)
     96          {
     97            TIMx->CR2 = (TIMx->CR2 & 0xFF00) | Xprescaler;
   \                     TIM_PrescalerConfig:
   \        0x0   0xE1D0'21B8        LDRH     R2,[R0, #+24]
   \        0x4   0xE212'2CFF        ANDS     R2,R2,#0xFF00
   \        0x8   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0xC   0xE191'1002        ORRS     R1,R1,R2
   \       0x10   0xE1C0'11B8        STRH     R1,[R0, #+24]
     98          }
   \       0x14   0xE12F'FF1E        BX       LR               ;; return
     99          
    100          /*******************************************************************************
    101          * Function Name  : TIM_PrescalerValue
    102          * Description    : This routine is used to get the TIM prescaler value 
    103          *                  when the internal clock is used.
    104          * Input          : - TIMx: specifies the timer to get its prescaler value.
    105          * Output         : None.
    106          * Return         : The Current TIM prescaler Value (8bit).
    107          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    108          u8 TIM_PrescalerValue (TIM_TypeDef *TIMx)
    109          {
    110            return TIMx->CR2 & 0x00FF;
   \                     TIM_PrescalerValue:
   \        0x0   0xE1D0'01B8        LDRH     R0,[R0, #+24]
   \        0x4   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \        0x8   0xE12F'FF1E        BX       LR               ;; return
    111          }
    112          
    113          /*******************************************************************************
    114          * Function Name  : TIM_ClockLevelConfig
    115          * Description    : This routine is used to configure the TIM clock level
    116          *                  when an external clock source is used.
    117          * Input          : - TIMx: specifies the TIM to be configured.
    118          *                  - Xedge: specifies the active edge of the external clock.
    119          *                    It can be:
    120          *                     TIM_RISING : The rising  edge.
    121          *                     TIM_FALLING: The falling edge.
    122          * Output         : None.
    123          * Return         : None.
    124          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    125          void TIM_ClockLevelConfig (TIM_TypeDef *TIMx, TIM_Clock_Edges Xedge)
    126          {
    127            if (Xedge == TIM_RISING)
   \                     TIM_ClockLevelConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0000        CMP      R1,#+0
   \        0x8   0x1A00'0003        BNE      ??TIM_ClockLevelConfig_0
    128            {
    129              TIMx->CR1 |= TIM_EXEDG_Mask;
   \        0xC   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x10   0xE391'1002        ORRS     R1,R1,#0x2
   \       0x14   0xE1C0'11B4        STRH     R1,[R0, #+20]
   \       0x18   0xEA00'0004        B        ??TIM_ClockLevelConfig_1
    130            }
    131            else
    132            {
    133              TIMx->CR1 &= ~TIM_EXEDG_Mask;
   \                     ??TIM_ClockLevelConfig_0:
   \       0x1C   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x20   0xE3A0'20FD        MOV      R2,#+253
   \       0x24   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x28   0xE012'1001        ANDS     R1,R2,R1
   \       0x2C   0xE1C0'11B4        STRH     R1,[R0, #+20]
    134            }
    135          }
   \                     ??TIM_ClockLevelConfig_1:
   \       0x30   0xE12F'FF1E        BX       LR               ;; return
    136          
    137          /*******************************************************************************
    138          * Function Name  : TIM_ClockLevelValue
    139          * Description    : This routine is used to get and return the clock active level
    140          *                  when using an external clock source
    141          * Input          : - TIMx: specifies the TIM to be configured.
    142          * Output         : None.
    143          * Return         : The external clock level of the specified timer.
    144          *                  It can be:            
    145          *                    TIM_RISING  : The rising  edge.
    146          *                    TIM_FALLING : The falling edge.
    147          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    148          TIM_Clock_Edges TIM_ClockLevelValue (TIM_TypeDef *TIMx)
    149          {
    150            if ((TIMx->CR1 & TIM_EXEDG_Mask) == 0)
   \                     TIM_ClockLevelValue:
   \        0x0   0xE1D0'01B4        LDRH     R0,[R0, #+20]
   \        0x4   0xE310'0002        TST      R0,#0x2
   \        0x8   0x1A00'0001        BNE      ??TIM_ClockLevelValue_0
    151            {
    152              return TIM_FALLING;	
   \        0xC   0xE3A0'0001        MOV      R0,#+1
   \       0x10   0xEA00'0000        B        ??TIM_ClockLevelValue_1
    153            }	
    154            else
    155            {
    156              return TIM_RISING;	
   \                     ??TIM_ClockLevelValue_0:
   \       0x14   0xE3A0'0000        MOV      R0,#+0
   \                     ??TIM_ClockLevelValue_1:
   \       0x18   0xE12F'FF1E        BX       LR               ;; return
    157            }
    158          }
    159          
    160          /*******************************************************************************
    161          * Function Name  : TIM_ICAPModeConfig
    162          * Description    : This routine is used to configure the input capture feature
    163          * Input          : - TIMx: specifies the TIM to be configured.
    164          *                  - Xchannel: specifies the input Capture Channel, it can be:
    165          *                     TIM_CHANNEL_A, TIM_CHANNEL_B
    166          *                  - Xedge: specifies the Active Edge, it can be:
    167          *                     TIM_RISING, TIM_FALLING
    168          * Output         : None.
    169          * Return         : None.
    170          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    171          void TIM_ICAPModeConfig (TIM_TypeDef  *TIMx, TIM_Channels Xchannel,
    172                                   TIM_Clock_Edges  Xedge)
    173          {
    174            switch (Xchannel)
   \                     TIM_ICAPModeConfig:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0000        CMP      R1,#+0
   \        0x8   0x0A00'0002        BEQ      ??TIM_ICAPModeConfig_0
   \        0xC   0xE351'0001        CMP      R1,#+1
   \       0x10   0x0A00'000D        BEQ      ??TIM_ICAPModeConfig_1
   \       0x14   0xEA00'0018        B        ??TIM_ICAPModeConfig_2
    175            {
    176              case TIM_CHANNEL_A :
    177                if (Xedge == TIM_RISING)
   \                     ??TIM_ICAPModeConfig_0:
   \       0x18   0xE212'20FF        ANDS     R2,R2,#0xFF      ;; Zero extend
   \       0x1C   0xE352'0000        CMP      R2,#+0
   \       0x20   0x1A00'0003        BNE      ??TIM_ICAPModeConfig_3
    178                {
    179                  TIMx->CR1 |= TIM_IEDGA_Mask;
   \       0x24   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x28   0xE391'1004        ORRS     R1,R1,#0x4
   \       0x2C   0xE1C0'11B4        STRH     R1,[R0, #+20]
   \       0x30   0xEA00'0004        B        ??TIM_ICAPModeConfig_4
    180                }
    181                else
    182                {
    183                  TIMx->CR1 &= ~TIM_IEDGA_Mask;
   \                     ??TIM_ICAPModeConfig_3:
   \       0x34   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x38   0xE3A0'20FB        MOV      R2,#+251
   \       0x3C   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x40   0xE012'1001        ANDS     R1,R2,R1
   \       0x44   0xE1C0'11B4        STRH     R1,[R0, #+20]
    184                }
    185                break;
   \                     ??TIM_ICAPModeConfig_4:
   \       0x48   0xEA00'000B        B        ??TIM_ICAPModeConfig_2
    186              case TIM_CHANNEL_B :
    187                if (Xedge == TIM_RISING)
   \                     ??TIM_ICAPModeConfig_1:
   \       0x4C   0xE212'20FF        ANDS     R2,R2,#0xFF      ;; Zero extend
   \       0x50   0xE352'0000        CMP      R2,#+0
   \       0x54   0x1A00'0003        BNE      ??TIM_ICAPModeConfig_5
    188                {
    189                  TIMx->CR1 |= TIM_IEDGB_Mask;
   \       0x58   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x5C   0xE391'1008        ORRS     R1,R1,#0x8
   \       0x60   0xE1C0'11B4        STRH     R1,[R0, #+20]
   \       0x64   0xEA00'0004        B        ??TIM_ICAPModeConfig_6
    190                }
    191                else
    192                {
    193                  TIMx->CR1 &= ~TIM_IEDGB_Mask;
   \                     ??TIM_ICAPModeConfig_5:
   \       0x68   0xE1D0'11B4        LDRH     R1,[R0, #+20]
   \       0x6C   0xE3A0'20F7        MOV      R2,#+247
   \       0x70   0xE382'2CFF        ORR      R2,R2,#0xFF00
   \       0x74   0xE012'1001        ANDS     R1,R2,R1
   \       0x78   0xE1C0'11B4        STRH     R1,[R0, #+20]
    194                }
    195                break;
    196            }
    197          }
   \                     ??TIM_ICAPModeConfig_6:
   \                     ??TIM_ICAPModeConfig_2:
   \       0x7C   0xE12F'FF1E        BX       LR               ;; return
    198          
    199          /*******************************************************************************
    200          * Function Name  : TIM_ICAPValue
    201          * Description    : This routine is used to get and return the Input Capture 
    202          *                  value.
    203          * Input          : - TIMx: specifies the TIM to check its Input Capture value.
    204          *                  - Xchannel: specifies the Input Capture channel, it can be:
    205          *                     TIM_Channel_A, TIM_Channel_B 
    206          * Output         : None.
    207          * Return         : The input capture value of the specified timer and channel.
    208          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
    209          u16 TIM_ICAPValue (TIM_TypeDef *TIMx, TIM_Channels Xchannel)
    210          {
    211            if (Xchannel == TIM_CHANNEL_A)
   \                     TIM_ICAPValue:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0000        CMP      R1,#+0
   \        0x8   0x1A00'0001        BNE      ??TIM_ICAPValue_0
    212            {
    213              return TIMx->ICAR;	
   \        0xC   0xE1D0'00B0        LDRH     R0,[R0, #+0]
   \       0x10   0xEA00'0000        B        ??TIM_ICAPValue_1
    214            } 	
    215            else
    216            {
    217              return TIMx->ICBR;	
   \                     ??TIM_ICAPValue_0:
   \       0x14   0xE1D0'00B4        LDRH     R0,[R0, #+4]
   \                     ??TIM_ICAPValue_1:
   \       0x18   0xE12F'FF1E        BX       LR               ;; return
    218            }
    219          }
