   \       0x14   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x18   0xE391'1001        ORRS     R1,R1,#0x1
   \       0x1C   0xE580'1000        STR      R1,[R0, #+0]
   \       0x20   0xEA00'0004        B        ??EIC_IRQConfig_1
     91            }
     92            else
     93            {
     94              EIC->ICR &= ~0x0001;
   \                     ??EIC_IRQConfig_0:
   \       0x24   0xE3E0'00FF        MVN      R0,#+255
   \       0x28   0xE3C0'0E70        BIC      R0,R0,#0x700
   \       0x2C   0xE590'1000        LDR      R1,[R0, #+0]
   \       0x30   0xE3D1'1001        BICS     R1,R1,#0x1
   \       0x34   0xE580'1000        STR      R1,[R0, #+0]
     95            }
     96          }
