     26          /*******************************************************************************
     27          * Function Name  : EIC_Init
     28          * Description    : Initialise the EIC using the load PC instruction
     29          *                   FIQ and IRQ are disabled, 
     30          *                   All channel interrupts are disabled, 
     31          *                   All pending bits are cleared.
     32          *                   The current priority level set to zero, 
     33          *                   IVR register initialized with the upper half of the load PC
     34          *                   instruction op-code, 
     35          *                   All SIR registers are initialized with the offset to the
     36          *                   corresponding IRQ routine vector.
     37          * Input          : None.
     38          * Output         : None.
     39          * Return         : None.
     40          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     41          void EIC_Init (void)
     42          {
     43            extern u32 T0TIMI_Addr;
     44            u8 bCounter;
     45            u32 dOffset = ((u32) & T0TIMI_Addr);
   \                     EIC_Init:
   \        0x0   0x....'....        LDR      R1,??DataTable0
     46          
     47            /* Disable FIQ and IRQ interrupts */
     48            EIC->ICR = 0x00000000;
   \        0x4   0xE3A0'0000        MOV      R0,#+0
   \        0x8   0xE3E0'20FF        MVN      R2,#+255
   \        0xC   0xE3C2'2E70        BIC      R2,R2,#0x700
   \       0x10   0xE582'0000        STR      R0,[R2, #+0]
     49          
     50            /* Disable all channels interrupts */
     51            EIC->IER = 0x00000000;
   \       0x14   0xE3E0'20DF        MVN      R2,#+223
   \       0x18   0xE3C2'2E70        BIC      R2,R2,#0x700
   \       0x1C   0xE582'0000        STR      R0,[R2, #+0]
     52          
     53            /* Clear all pending bits */
     54            EIC->IPR = 0xFFFFFFFF;
   \       0x20   0xE3E0'2000        MVN      R2,#+0
   \       0x24   0xE3E0'30BF        MVN      R3,#+191
   \       0x28   0xE3C3'3E70        BIC      R3,R3,#0x700
   \       0x2C   0xE583'2000        STR      R2,[R3, #+0]
     55          
     56            /* Disable all FIQ channels interrupts and clear FIQ */
     57            EIC->FIR = 0x0000000C;
   \       0x30   0xE3A0'200C        MOV      R2,#+12
   \       0x34   0xE3E0'30E3        MVN      R3,#+227
   \       0x38   0xE3C3'3E70        BIC      R3,R3,#0x700
   \       0x3C   0xE583'2000        STR      R2,[R3, #+0]
     58          
     59            /* channels pending bits */
     60            /* Set the current priority level to zero */
     61            EIC->CIPR = 0x00000000;
   \       0x40   0xE3E0'20F7        MVN      R2,#+247
   \       0x44   0xE3C2'2E70        BIC      R2,R2,#0x700
   \       0x48   0xE582'0000        STR      R0,[R2, #+0]
     62          
     63            /* IVR = high half of load PC instruction */
     64            EIC->IVR  = 0xE59F0000;
   \       0x4C   0xE3A0'24E5        MOV      R2,#-452984832
   \       0x50   0xE382'289F        ORR      R2,R2,#0x9F0000
   \       0x54   0xE3E0'30E7        MVN      R3,#+231
   \       0x58   0xE3C3'3E70        BIC      R3,R3,#0x700
   \       0x5C   0xE583'2000        STR      R2,[R3, #+0]
     65          
     66            dOffset = (dOffset + 0x00007E0) << 16;
   \       0x60   0xE291'1E7E        ADDS     R1,R1,#+2016
   \       0x64   0xE1B0'1801        LSLS     R1,R1,#+16
     67          
     68            /* Initialize SIRn registers */
     69            for (bCounter = 0; bCounter < 32; bCounter++)
   \       0x68   0xEA00'0008        B        ??EIC_Init_0
     70            {
     71              EIC->SIR[bCounter] = dOffset | 0xF0000000;
   \                     ??EIC_Init_1:
   \       0x6C   0xE391'24F0        ORRS     R2,R1,#0xF0000000
   \       0x70   0xE3E0'309F        MVN      R3,#+159
   \       0x74   0xE3C3'3E70        BIC      R3,R3,#0x700
   \       0x78   0xE1B0'C000        MOVS     R12,R0
   \       0x7C   0xE21C'C0FF        ANDS     R12,R12,#0xFF    ;; Zero extend
   \       0x80   0xE1B0'C10C        LSLS     R12,R12,#+2
   \       0x84   0xE783'200C        STR      R2,[R3, +R12]
     72              dOffset += 0x00000004 << 16;
   \       0x88   0xE291'1A40        ADDS     R1,R1,#+262144
     73            }
   \       0x8C   0xE290'0001        ADDS     R0,R0,#+1
   \                     ??EIC_Init_0:
   \       0x90   0xE1B0'2000        MOVS     R2,R0
   \       0x94   0xE212'20FF        ANDS     R2,R2,#0xFF      ;; Zero extend
   \       0x98   0xE352'0020        CMP      R2,#+32
   \       0x9C   0xBAFF'FFF2        BLT      ??EIC_Init_1
     74          }
   \       0xA0   0xE12F'FF1E        BX       LR               ;; return
     75          
