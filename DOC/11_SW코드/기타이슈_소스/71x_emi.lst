     28          /*******************************************************************************
     29          * Function Name  : EMI_Config
     30          * Description    : This routine is used, for each bank, to configure cycle
     31          *                  length and bus size.
     32          * Input          : - Bank_n: selects the bank to be configured, it can be:
     33          *                     EMI_BANK0, EMI_BANK1, EMI_BANK2, EMI_BANK3
     34          *                  - B_SIZE: specifies the effective external bus size for 
     35          *                    an access to Bank n. It can be:
     36          *                     EMI_SIZE_8: 8-bit bus length.
     37          *                     EMI_SIZE_16: 16-bit bus lenght.
     38          *                  - C_LENGTH: specifies the number of wait states to be 
     39          *                    inserted in any read/write cycle performed in Bank n.
     40          * Output         : None.
     41          * Return         : None.
     42          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     43          void EMI_Config (u8 Bank_n, u16 B_SIZE, u16 C_LENGTH)
     44          {   
     45            EMI_BankConfig(Bank_n) = (B_SIZE & 0x03) | ((C_LENGTH & 0x0F) << 2);
   \                     EMI_Config:
   \        0x0   0xE211'1003        ANDS     R1,R1,#0x3
   \        0x4   0xE3A0'303C        MOV      R3,#+60
   \        0x8   0xE013'2102        ANDS     R2,R3,R2, LSL #+2
   \        0xC   0xE192'1001        ORRS     R1,R2,R1
   \       0x10   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x14   0xE3A0'2004        MOV      R2,#+4
   \       0x18   0xE010'0092        MULS     R0,R2,R0
   \       0x1C   0xE290'046C        ADDS     R0,R0,#+1811939328
   \       0x20   0xE1C0'10B0        STRH     R1,[R0, #+0]
     46          }
   \       0x24   0xE12F'FF1E        BX       LR               ;; return
     47          
     48          /*******************************************************************************
     49          * Function Name  : EMI_Enable
     50          * Description    : This routine is used, for each bank, to enable or disable 
     51          *                  the specified EMI bank.
     52          * Input          : - Bank_n: selects the bank to be configured, it can be:
     53          *                     EMI_BANK0, EMI_BANK1, EMI_BANK2, EMI_BANK3
     54          *                  - NewState: specifies wether the EMI bank will be enabled or
     55          *                    disabled. It can be:
     56          *                     ENABLE: enable the specified EMI bank.
     57          *                     DISABLE: disable the specified EMI bank.
     58          * Output         : None.
     59          * Return         : None.
     60          *******************************************************************************/

   \                                 In section .text, align 4, keep-with-next
     61          void EMI_Enable (u8 Bank_n, FunctionalState NewState)
     62          {
     63            if (NewState == ENABLE)
   \                     EMI_Enable:
   \        0x0   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \        0x4   0xE351'0001        CMP      R1,#+1
   \        0x8   0x1A00'000C        BNE      ??EMI_Enable_0
     64            {
     65              EMI_BankConfig(Bank_n) |= EMI_ENABLE;
   \        0xC   0xE1B0'1000        MOVS     R1,R0
   \       0x10   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \       0x14   0xE3A0'2004        MOV      R2,#+4
   \       0x18   0xE011'0192        MULS     R1,R2,R1
   \       0x1C   0xE291'146C        ADDS     R1,R1,#+1811939328
   \       0x20   0xE1D1'10B0        LDRH     R1,[R1, #+0]
   \       0x24   0xE391'1C80        ORRS     R1,R1,#0x8000
   \       0x28   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x2C   0xE3A0'2004        MOV      R2,#+4
   \       0x30   0xE010'0092        MULS     R0,R2,R0
   \       0x34   0xE290'046C        ADDS     R0,R0,#+1811939328
   \       0x38   0xE1C0'10B0        STRH     R1,[R0, #+0]
   \       0x3C   0xEA00'000C        B        ??EMI_Enable_1
     66            }
     67            else
     68            {
     69              EMI_BankConfig(Bank_n) &= ~EMI_ENABLE;
   \                     ??EMI_Enable_0:
   \       0x40   0xE1B0'1000        MOVS     R1,R0
   \       0x44   0xE211'10FF        ANDS     R1,R1,#0xFF      ;; Zero extend
   \       0x48   0xE3A0'2004        MOV      R2,#+4
   \       0x4C   0xE011'0192        MULS     R1,R2,R1
   \       0x50   0xE291'146C        ADDS     R1,R1,#+1811939328
   \       0x54   0xE1D1'10B0        LDRH     R1,[R1, #+0]
   \       0x58   0xE1B0'1881        LSLS     R1,R1,#+17
   \       0x5C   0xE1B0'18A1        LSRS     R1,R1,#+17
   \       0x60   0xE210'00FF        ANDS     R0,R0,#0xFF      ;; Zero extend
   \       0x64   0xE3A0'2004        MOV      R2,#+4
   \       0x68   0xE010'0092        MULS     R0,R2,R0
   \       0x6C   0xE290'046C        ADDS     R0,R0,#+1811939328
   \       0x70   0xE1C0'10B0        STRH     R1,[R0, #+0]
     70            }
     71          }
   \                     ??EMI_Enable_1:
   \       0x74   0xE12F'FF1E        BX       LR               ;; return
     72          
