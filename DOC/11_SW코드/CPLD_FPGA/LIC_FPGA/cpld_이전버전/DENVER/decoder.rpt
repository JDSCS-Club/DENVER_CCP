*******************************  Equations  ********************************

********** Mapped Logic **********

FDCPE_BOOT_2_INT_CS: FDCPE port map (BOOT_2_INT_CS,'0','0',BOOT_2_INT_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
BOOT_2_INT_CS_CLR <= (RST AND NOT STRB AND NOT A(21) AND NOT A(19) AND A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));


BOOT_2_INT_SEL <= ((RST AND BOOT_2_INT_SEL)
	OR (RST AND NOT BOOT_2_INT_CS));


D_I(0) <= NOT (((NOT RUN_LED AND INT_READ_CS)
	OR (BOOT_2_INT_SEL AND NOT XL16L784_INT AND NOT INT_READ_CS)));
D(0) <= D_I(0) when D_OE(0) = '1' else 'Z';
D_OE(0) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(1) <= NOT (((NOT ERR_LED AND INT_READ_CS)
	OR (NOT BOOT_2_INT_SEL AND ROM_SERIAL_SW AND NOT INT_READ_CS)));
D(1) <= D_I(1) when D_OE(1) = '1' else 'Z';
D_OE(1) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(2) <= '0';
D(2) <= D_I(2) when D_OE(2) = '1' else 'Z';
D_OE(2) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(3) <= '0';
D(3) <= D_I(3) when D_OE(3) = '1' else 'Z';
D_OE(3) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(4) <= '0';
D(4) <= D_I(4) when D_OE(4) = '1' else 'Z';
D_OE(4) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(5) <= '0';
D(5) <= D_I(5) when D_OE(5) = '1' else 'Z';
D_OE(5) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(6) <= '0';
D(6) <= D_I(6) when D_OE(6) = '1' else 'Z';
D_OE(6) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_I(7) <= '0';
D(7) <= D_I(7) when D_OE(7) = '1' else 'Z';
D_OE(7) <= D_0_IOBUFE/D_0_IOBUFE_TRST;


D_0_IOBUFE/D_0_IOBUFE_TRST <= ((RST AND NOT INT_READ_CS)
	OR (RST AND RWB AND NOT LED_CS));


EDGE_MODE <= '1';

FDCPE_ERR_LED: FDCPE port map (ERR_LED,D(1).PIN,NOT WR_BUFS(1),NOT RST,'0',NOT LED_CS);





FDCPE_FROM_CS: FDCPE port map (FROM_CS,'0','0',FROM_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
FROM_CS_CLR <= (RST AND NOT STRB AND NOT A(21) AND NOT A(19) AND NOT A(18) AND NOT A(23) AND 
	NOT A(22) AND A(20));


INT0 <= NOT ((BOOT_2_INT_SEL AND NOT XL16L784_INT));


INT1 <= NOT ((NOT BOOT_2_INT_SEL AND ROM_SERIAL_SW));


INT2 <= NOT ((BOOT_2_INT_SEL AND NOT W5100_INT));


INT3 <= NOT ((NOT BOOT_2_INT_SEL AND NOT ROM_SERIAL_SW));

FDCPE_INT_READ_CS: FDCPE port map (INT_READ_CS,'0','0',INT_READ_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
INT_READ_CS_CLR <= (RST AND NOT STRB AND A(21) AND NOT A(19) AND NOT A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));

FDCPE_LED_CS: FDCPE port map (LED_CS,'0','0',LED_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
LED_CS_CLR <= (RST AND NOT STRB AND NOT A(21) AND A(19) AND NOT A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));


LRST_I <= '0';
LRST <= LRST_I when LRST_OE = '1' else 'Z';
LRST_OE <= '0';


NVSRAM_CS <= ((NOT RST)
	OR (STRB)
	OR (NVSRAM_CS AND NOT A(22))
	OR (A(21) AND NOT A(23) AND A(20))
	OR (A(19) AND NOT A(23) AND A(20))
	OR (A(18) AND NOT A(23) AND A(20))
	OR (A(18) AND NOT A(22) AND A(20))
	OR (A(21) AND NOT A(22) AND A(20))
	OR (A(19) AND NOT A(22) AND A(20))
	OR (A(21) AND A(19) AND A(18) AND NOT A(23) AND NOT A(20))
	OR (A(21) AND A(19) AND A(18) AND NOT A(22) AND NOT A(20))
	OR (NVSRAM_CS AND NOT A(23))
	OR (A(23) AND NOT A(22))
	OR (NOT A(23) AND A(22)));


RD <= NOT ((NOT STRB AND RWB));


RDY <= '0';

FDCPE_RUN_LED: FDCPE port map (RUN_LED,D(0).PIN,NOT WR_BUFS(1),NOT RST,'0',NOT LED_CS);


SERVICE_LON <= SERVICE_SWITCH;

FDCPE_W5100_CS: FDCPE port map (W5100_CS,'0','0',W5100_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
W5100_CS_CLR <= (RST AND NOT STRB AND NOT A(21) AND A(19) AND A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));


WDI <= ((H3 AND NOT ROM_SERIAL_SW)
	OR (WDI_SEL_FLAG AND ROM_SERIAL_SW AND WDI_CS)
	OR (NOT WDI_SEL_FLAG AND ROM_SERIAL_SW AND FROM_CS));

FDCPE_WDI_CS: FDCPE port map (WDI_CS,'0','0',WDI_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
WDI_CS_CLR <= (RST AND NOT STRB AND NOT A(21) AND NOT A(19) AND NOT A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));


WDI_CS/WDI_CS_SETF__$INT <= ((RST AND NOT STRB AND A(23) AND A(22))
	OR (RST AND NOT STRB AND NOT A(21) AND NOT A(23) AND NOT A(22) AND NOT A(20))
	OR (RST AND NOT STRB AND NOT A(19) AND NOT A(23) AND NOT A(22) AND NOT A(20))
	OR (RST AND NOT STRB AND NOT A(18) AND NOT A(23) AND NOT A(22) AND NOT A(20))
	OR (RST AND NOT STRB AND NOT A(21) AND NOT A(19) AND NOT A(18) AND NOT A(23) AND 
	NOT A(22)));


WDI_SEL_FLAG <= ((RST AND WDI_SEL_FLAG)
	OR (RST AND NOT WDI_CS));


WR <= NOT ((NOT STRB AND NOT RWB));

FDCPE_WR_BUFS0: FDCPE port map (WR_BUFS(0),WR_BUFS_D(0),H3,'0',NOT RST);
WR_BUFS_D(0) <= (NOT STRB AND NOT RWB);

FDCPE_WR_BUFS1: FDCPE port map (WR_BUFS(1),WR_BUFS(0),H3,'0',NOT RST);

FDCPE_XL16L784_CS: FDCPE port map (XL16L784_CS,'0','0',XL16L784_CS_CLR,NOT WDI_CS/WDI_CS_SETF__$INT);
XL16L784_CS_CLR <= (RST AND NOT STRB AND A(21) AND NOT A(19) AND A(18) AND NOT A(23) AND 
	NOT A(22) AND NOT A(20));

